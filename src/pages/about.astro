---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import Hero from '@/components/Hero.astro';
import TrustBadge from '@/components/TrustBadge.astro';
import CTASection from '@/components/CTASection.astro';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  name: 'About Fimil',
  url: 'https://fimil.dev/about',
  description: "Learn about Fimil's mission to unify application security.",
  mainEntity: {
    '@type': 'Organization',
    name: 'Fimil',
    url: 'https://fimil.dev',
    logo: 'https://fimil.dev/logo-icon-color.svg',
    founder: { '@type': 'Person', name: 'Ethan', jobTitle: 'Founder' },
    foundingDate: '2025',
  },
};

const scanners = [
  { name: 'Semgrep', description: 'SAST', icon: '\u{1F50D}' },
  { name: 'Trivy', description: 'SCA & Containers', icon: '\u{1F4E6}' },
  { name: 'Gitleaks', description: 'Secrets Detection', icon: '\u{1F511}' },
  { name: 'Checkov', description: 'IaC Scanning', icon: '\u{1F3D7}\u{FE0F}' },
  { name: 'Grype', description: 'Vulnerability DB', icon: '\u{1F6E1}\u{FE0F}' },
  { name: 'Syft', description: 'SBOM Generation', icon: '\u{1F4CB}' },
];

const timeline = [
  {
    date: 'Late 2025',
    title: 'Founded',
    description: 'Fimil was born from the frustration of managing too many security scanners.',
  },
  {
    date: 'Early 2026',
    title: 'Core Platform',
    description:
      'Unified dashboard with scanner orchestration, deduplication, and Git integrations.',
  },
  {
    date: 'Early 2026',
    title: 'Intelligence Layer',
    description: 'Priority scoring, EPSS enrichment, reachability analysis, and auto-triage rules.',
  },
  {
    date: '2026',
    title: 'Public Beta',
    description: 'Fimil Cloud and Enterprise editions available to all teams.',
  },
];

const values = [
  {
    title: 'Security First',
    description:
      "Security isn't an afterthought \u2014 it's the foundation. We build every feature with security best practices in mind, so you can trust us with your code.",
    icon: '\u{1F6E1}\u{FE0F}',
  },
  {
    title: 'Developer Experience',
    description:
      "Security tools shouldn't slow developers down. We design Fimil to fit naturally into existing workflows, making security easy to adopt.",
    icon: '\u{1F465}',
  },
  {
    title: 'Open Source Powered',
    description:
      'We believe in the power of open source. Fimil orchestrates the best OSS security tools, giving back to the community that makes our work possible.',
    icon: '\u{1F4BB}',
  },
  {
    title: 'Privacy by Design',
    description:
      'Your source code never leaves your control. We scan, analyze, and delete \u2014 never storing your proprietary code on our systems.',
    icon: '\u{1F512}',
  },
];
---

<BaseLayout
  title="About \u2014 Fimil"
  description="Learn about Fimil's mission to unify application security with intelligent orchestration of open-source scanners."
  jsonLd={jsonLd}
>
  <Breadcrumbs items={[{ label: 'About' }]} />
  <Hero
    headline="Building the Future of Application Security"
    subheadline="We believe security should be accessible, actionable, and integrated into every developer's workflow."
  />

  {/* Story */}
  <section class="py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold tracking-tight text-gray-900">Our Story</h2>
      <div class="mt-6 space-y-4 text-gray-600">
        <p>
          Modern development teams face an impossible challenge: secure your code while moving fast.
          The security landscape is fragmented &mdash; dozens of specialized tools, each with their
          own interface, alert format, and learning curve.
        </p>
        <p>
          We've been there. As developers and security engineers, we spent countless hours
          context-switching between tools, triaging duplicate alerts, and explaining to executives
          why "10,000 findings" didn't mean the sky was falling. We maintained sprawling
          spreadsheets just to track which scanner found which CVE, which ones were duplicates, and
          which ones actually mattered.
        </p>
        <p>
          The "aha moment" came when we realized the problem wasn't the scanners themselves &mdash;
          they're excellent at what they do. The problem was the lack of orchestration. Nobody was
          normalizing outputs, deduplicating across tools, or intelligently prioritizing the
          results. Every team was solving the same integration headache independently.
        </p>
        <p>
          Fimil was born from that realization. Rather than building yet another proprietary
          scanner, we chose to wrap the best open-source tools the community has already created.
          Semgrep for SAST, Trivy and Grype for SCA, Gitleaks for secrets, Checkov for IaC &mdash;
          each one best-in-class, orchestrated behind a single dashboard.
        </p>
        <p>
          Today, Fimil helps development teams worldwide find and fix vulnerabilities faster. We
          integrate SAST, SCA, secrets detection, IaC scanning, and container security into <a
            href="/features"
            class="text-fimil-600 hover:text-fimil-700">one unified dashboard</a
          > &mdash; reducing noise by 90% and helping teams focus on the issues that matter most.
        </p>
      </div>
    </div>
  </section>

  {/* Team */}
  <section class="border-t border-gray-200/60 bg-gray-50 py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-center text-2xl font-bold tracking-tight text-gray-900">
        Who's Behind Fimil
      </h2>
      <div class="mt-10 flex justify-center">
        <div class="text-center">
          <div
            class="mx-auto flex h-24 w-24 items-center justify-center rounded-full bg-fimil-600 text-3xl font-bold text-white"
          >
            E
          </div>
          <h3 class="mt-4 text-lg font-semibold text-gray-900">Ethan</h3>
          <p class="text-sm text-fimil-600">Founder</p>
          <p class="mt-3 max-w-sm text-sm text-gray-600">
            I built Fimil because I was tired of wrangling a dozen security scanners across multiple
            teams &mdash; maintaining spreadsheets to track which tool found which CVE, which ones
            were duplicates, and which ones actually mattered. Nobody should have to solve that
            orchestration problem from scratch, so I'm building the platform I wish I'd had.
          </p>
        </div>
      </div>
    </div>
  </section>

  {/* Open Source Philosophy */}
  <section class="py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold tracking-tight text-gray-900">Orchestrate, Don't Reinvent</h2>
      <div class="mt-6 space-y-4 text-gray-600">
        <p>
          The open-source security community has built incredible tools. Semgrep for static
          analysis. Trivy and Grype for dependency scanning. Gitleaks and TruffleHog for secrets
          detection. Checkov for infrastructure-as-code. Each one is best-in-class at what it does.
        </p>
        <p>
          We don't try to replace these tools &mdash; we orchestrate them. Fimil runs each scanner
          in an isolated container, normalizes the output into a common format, deduplicates across
          tools, and applies <a href="/compare" class="text-fimil-600 hover:text-fimil-700"
            >intelligent prioritization</a
          >. The result is a single view that's greater than the sum of its parts.
        </p>
        <p>
          This philosophy means you always get the latest and greatest from the security community,
          without the operational burden of managing each tool individually. When a new scanner
          emerges, we integrate it. When an existing one improves, you benefit automatically.
        </p>
      </div>
    </div>
  </section>

  {/* Trust Badges */}
  <section class="border-t border-gray-200/60 bg-white py-16">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-center text-2xl font-bold tracking-tight text-gray-900">
        The tools that power Fimil
      </h2>
      <div class="mt-10 grid grid-cols-2 gap-8 sm:grid-cols-3 lg:grid-cols-6">
        {
          scanners.map((s) => (
            <TrustBadge name={s.name} description={s.description} icon={s.icon} />
          ))
        }
      </div>
    </div>
  </section>

  {/* Timeline */}
  <section class="border-t border-gray-200/60 bg-gray-50 py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-center text-2xl font-bold tracking-tight text-gray-900">Our Journey</h2>
      <div class="relative mt-10 ml-4 border-l-2 border-fimil-200 pl-8">
        {
          timeline.map((item) => (
            <div class="scroll-hidden relative mb-10 last:mb-0">
              <div class="absolute top-1 -left-[2.6rem] h-4 w-4 rounded-full border-2 border-fimil-500 bg-white" />
              <span class="text-xs font-medium text-fimil-600">{item.date}</span>
              <h3 class="mt-1 text-lg font-semibold text-gray-900">{item.title}</h3>
              <p class="mt-1 text-sm text-gray-600">{item.description}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  {/* Values */}
  <section class="py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-center text-2xl font-bold tracking-tight text-gray-900">Our Values</h2>
      <p class="mt-4 text-center text-lg text-gray-600">
        The principles that guide everything we build.
      </p>
      <div class="mt-10 grid gap-6 sm:grid-cols-2">
        {
          values.map((v) => (
            <div class="scroll-hidden rounded-xl border border-gray-200 bg-white p-6">
              <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-lg bg-fimil-100 text-xl text-fimil-600">
                {v.icon}
              </div>
              <h3 class="text-lg font-semibold text-gray-900">{v.title}</h3>
              <p class="mt-2 text-sm text-gray-600">{v.description}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  {/* Mission */}
  <section class="border-t border-gray-200/60 bg-gray-50 py-20">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold tracking-tight text-gray-900">Our Mission</h2>
      <p class="mt-6 text-xl text-gray-600">
        To make application security accessible to every development team, regardless of size or
        security expertise.
      </p>
      <p class="mt-4 text-lg text-gray-500">
        We're building a world where security is a natural part of the development process &mdash;
        not a bottleneck, not an afterthought, but an integrated, automated, and actionable part of
        shipping great software.
      </p>
    </div>
  </section>

  <CTASection
    headline="Help Us Make Software More Secure"
    description="Help us make the world's software more secure."
    cta={{ label: 'Join Waitlist', href: '/#waitlist' }}
  />
</BaseLayout>
