---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import Hero from '@/components/Hero.astro';
import Section from '@/components/Section.astro';
import CTASection from '@/components/CTASection.astro';
import LogoWall from '@/components/LogoWall.astro';
import Icon from '@/components/Icon.astro';
import type { IconName } from '@/lib/icons';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  name: 'About Fimil',
  url: 'https://fimil.dev/about',
  description: 'The honest story behind Fimil — built full-time by one security engineer.',
  mainEntity: {
    '@type': 'Organization',
    name: 'Fimil',
    url: 'https://fimil.dev',
    logo: 'https://fimil.dev/logo-icon-color.svg',
    founder: { '@type': 'Person', name: 'Ethan Aldrich', jobTitle: 'Founder' },
    foundingDate: '2025',
  },
};

const timeline = [
  {
    date: 'Late 2025',
    title: 'Founded',
    description: 'Fimil started as a way out of spreadsheet-triaging a dozen security scanners.',
  },
  {
    date: 'Early 2026',
    title: 'Core platform + intelligence layer',
    description:
      'Scanner orchestration, cross-tool dedup, finding groups, priority scoring, auto-triage, and auto-remediation PRs.',
  },
  {
    date: 'Spring 2026',
    title: 'AI Pentest engine',
    description:
      'The autonomous agent: 15 attack vectors, replay validation, MFA login, browser-driven testing, PoC export.',
  },
  {
    date: 'Now',
    title: 'Early access',
    description:
      'Onboarding teams in waves from the waitlist while the platform hardens in production.',
  },
];

const principles: { icon: IconName; title: string; description: string }[] = [
  {
    icon: 'shield-check',
    title: 'Claims require proof',
    description:
      "A finding you can't reproduce is a guess. The pentest validator replays every exploit before it's reported, and this site only states what the code actually does.",
  },
  {
    icon: 'git-pull-request',
    title: 'The fix is the product',
    description:
      'Detection is table stakes. The deliverable that matters is the pull request that closes the finding.',
  },
  {
    icon: 'lock',
    title: 'Your code stays yours',
    description:
      'Scans run in isolated, ephemeral environments; sources are deleted when the scan completes. Self-hosted and air-gapped installs exist for teams that need code to never leave their network.',
  },
  {
    icon: 'terminal',
    title: 'Open source gets credit',
    description:
      'Fimil names every scanner it orchestrates, on every finding. The community built great tools; the value I add is validation, correlation, and remediation on top.',
  },
];
---

<BaseLayout
  title="About — Ethan Aldrich, Founder of Fimil"
  description="Fimil is built full-time by one person. The honest story of why detection without proof and fixes wasn't enough."
  jsonLd={jsonLd}
>
  <Breadcrumbs items={[{ label: 'About' }]} />
  <Hero
    headline="I got tired of security tools that just point at problems."
    subheadline="Fimil is built by one person, full-time, in the open. Here's the story — without the invented 'we'."
  />

  {/* Story */}
  <Section spacing="md">
    <div class="mx-auto max-w-3xl">
      <h2 class="text-2xl font-bold tracking-tight text-ink">The story</h2>
      <div class="mt-6 space-y-4 text-ink-soft">
        <p>
          I've run security tooling across a fleet of internal apps, and the routine was always the
          same: a dozen specialized scanners, each with its own interface, alert format, and
          learning curve. I maintained sprawling spreadsheets just to track which scanner found
          which CVE, which findings were duplicates, and which ones actually mattered — and then
          explained to leadership why "10,000 findings" didn't mean the sky was falling.
        </p>
        <p>
          The first realization was that the scanners weren't the problem — they're excellent at
          what they do. Nobody was normalizing their output, deduplicating across tools, or
          prioritizing the results. Every team solves that same integration headache independently.
          So I built the orchestration layer: one pipeline, one finding schema, one signal.
        </p>
        <p>
          The second realization came later: even a perfectly deduplicated list is still homework. A
          finding without proof gets argued about, and a finding without a fix gets postponed.
          That's why Fimil grew a <a href="/pentest" class="text-fimil-400 hover:text-fimil-300"
            >pentest agent that validates exploits by replaying them</a
          > and a <a href="/platform" class="text-fimil-400 hover:text-fimil-300"
            >remediation engine that opens the fix PR</a
          >. Find it, prove it, fix it — in that order, because that's the order the mechanics
          require.
        </p>
        <p>
          Fimil is in early access today, onboarding teams in waves. If the story resonates, <a
            href="/#waitlist"
            class="text-fimil-400 hover:text-fimil-300">get on the list</a
          > — early users shape what gets built next.
        </p>
      </div>
    </div>
  </Section>

  {/* Founder */}
  <Section variant="panel" spacing="md">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="text-2xl font-bold tracking-tight text-ink">Who's behind Fimil</h2>
      <div class="mt-10 flex justify-center">
        <div class="text-center">
          <div
            class="mx-auto flex h-24 w-24 items-center justify-center rounded-full border border-fimil-400/40 bg-fimil-400/10 font-mono text-3xl font-bold text-fimil-300"
          >
            EA
          </div>
          <h3 class="mt-4 text-lg font-semibold text-ink">Ethan Aldrich</h3>
          <p class="text-sm text-fimil-400">Founder</p>
          <p class="mt-3 max-w-md text-sm leading-6 text-ink-soft">
            I build Fimil full-time — the API, the agent, the scanners, this website. Being a
            one-person company cuts both ways, so I'll say both halves out loud: you talk directly
            to the person who wrote the code, and you should ask the "what if you get hit by a bus"
            question. The honest answers are the self-hosted option, an open <a
              href="https://trust.fimil.dev"
              class="text-fimil-400 hover:text-fimil-300"
              target="_blank"
              rel="noopener">trust center</a
            >, and a platform built on open-source scanners you could run without me.
          </p>
        </div>
      </div>
    </div>
  </Section>

  {/* Philosophy */}
  <Section spacing="md">
    <div class="mx-auto max-w-3xl">
      <h2 class="text-2xl font-bold tracking-tight text-ink">Orchestrate, don't reinvent</h2>
      <div class="mt-6 space-y-4 text-ink-soft">
        <p>
          The open-source security community has built incredible tools — Semgrep for static
          analysis, Trivy and Grype for dependencies, Gitleaks and TruffleHog for secrets, Checkov
          for infrastructure-as-code, ZAP and Nuclei for dynamic testing, Prowler for cloud posture.
          Each is best-in-class at what it does.
        </p>
        <p>
          Fimil doesn't replace them — it runs each scanner in an isolated environment, normalizes
          the output into a common schema, deduplicates across tools, and applies an auditable
          priority score. And where the community has no tool — validated, autonomous pentesting — I
          built one.
        </p>
      </div>
      <div class="mt-10">
        <LogoWall />
      </div>
    </div>
  </Section>

  {/* Timeline */}
  <Section variant="panel" spacing="md">
    <div class="mx-auto max-w-3xl">
      <h2 class="text-center text-2xl font-bold tracking-tight text-ink">The road so far</h2>
      <div class="relative mt-10 ml-4 border-l border-edge pl-8">
        {
          timeline.map((item) => (
            <div class="scroll-hidden relative mb-10 last:mb-0">
              <div class="absolute top-1 -left-[2.3rem] h-3 w-3 rounded-full border-2 border-fimil-400 bg-ground" />
              <span class="font-mono text-xs text-fimil-400">{item.date}</span>
              <h3 class="mt-1 text-lg font-semibold text-ink">{item.title}</h3>
              <p class="mt-1 text-sm text-ink-soft">{item.description}</p>
            </div>
          ))
        }
      </div>
    </div>
  </Section>

  {/* Principles */}
  <Section spacing="md">
    <div class="mx-auto max-w-5xl">
      <h2 class="text-center text-2xl font-bold tracking-tight text-ink">Principles</h2>
      <p class="mt-4 text-center text-lg text-ink-soft">
        Four rules that decide what gets built and what gets cut.
      </p>
      <div class="mt-10 grid gap-6 sm:grid-cols-2">
        {
          principles.map((p) => (
            <div class="scroll-hidden rounded-xl border border-edge bg-panel p-6">
              <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-lg border border-fimil-400/20 bg-fimil-400/10">
                <Icon name={p.icon} class="h-5 w-5 text-fimil-400" />
              </div>
              <h3 class="text-lg font-semibold text-ink">{p.title}</h3>
              <p class="mt-2 text-sm leading-6 text-ink-soft">{p.description}</p>
            </div>
          ))
        }
      </div>
    </div>
  </Section>

  <CTASection
    headline="Help me make software more secure."
    description="Get early access, run it against your own repos, and tell me what breaks. I read every message."
    cta={{ label: 'Get early access', href: '/#waitlist' }}
  />
</BaseLayout>
