---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import Hero from '@/components/Hero.astro';
import CTASection from '@/components/CTASection.astro';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Fimil vs SonarQube, Snyk, GitHub Advanced Security',
  url: 'https://fimil.dev/compare',
  description:
    'An honest comparison of Fimil with SonarQube, Snyk, and GitHub Advanced Security — including the rows where they win.',
  about: [
    { '@type': 'SoftwareApplication', name: 'Fimil' },
    { '@type': 'SoftwareApplication', name: 'SonarQube' },
    { '@type': 'SoftwareApplication', name: 'Snyk' },
    { '@type': 'SoftwareApplication', name: 'GitHub Advanced Security' },
  ],
};

type CellValue = boolean | string;

interface ComparisonRow {
  feature: string;
  fimil: CellValue;
  sonarqube: CellValue;
  snyk: CellValue;
  github: CellValue;
}

type ComparisonCategory = {
  name: string;
  rows: ComparisonRow[];
};

const categories: ComparisonCategory[] = [
  {
    name: 'Scanning Coverage',
    rows: [
      { feature: 'SAST', fimil: true, sonarqube: true, snyk: true, github: true },
      {
        feature: 'SCA / Dependency Scanning',
        fimil: true,
        sonarqube: false,
        snyk: true,
        github: true,
      },
      { feature: 'Secrets Detection', fimil: true, sonarqube: false, snyk: false, github: true },
      { feature: 'IaC Scanning', fimil: true, sonarqube: false, snyk: true, github: false },
      {
        feature: 'Container Image Scanning',
        fimil: true,
        sonarqube: false,
        snyk: true,
        github: false,
      },
      { feature: 'DAST', fimil: true, sonarqube: false, snyk: 'Add-on', github: false },
      {
        feature: 'CSPM (Cloud Posture)',
        fimil: true,
        sonarqube: false,
        snyk: false,
        github: false,
      },
      { feature: 'SBOM Generation', fimil: true, sonarqube: false, snyk: true, github: true },
      {
        feature: 'Multi-Scanner Orchestration',
        fimil: true,
        sonarqube: false,
        snyk: false,
        github: false,
      },
      {
        feature: 'Cross-Tool Deduplication',
        fimil: true,
        sonarqube: false,
        snyk: false,
        github: false,
      },
    ],
  },
  {
    name: 'Autonomous Pentest',
    rows: [
      { feature: 'AI Pentest Agent', fimil: true, sonarqube: false, snyk: false, github: false },
      {
        feature: 'Exploit-Validated Findings',
        fimil: true,
        sonarqube: false,
        snyk: false,
        github: false,
      },
      {
        feature: 'PoC + curl Reproduction',
        fimil: true,
        sonarqube: false,
        snyk: false,
        github: false,
      },
      {
        feature: 'Authenticated Testing with TOTP MFA',
        fimil: true,
        sonarqube: false,
        snyk: false,
        github: false,
      },
      {
        feature: 'OpenAPI / GraphQL-Aware Discovery',
        fimil: true,
        sonarqube: false,
        snyk: false,
        github: false,
      },
      {
        feature: 'Fix PR from Confirmed Finding',
        fimil: true,
        sonarqube: false,
        snyk: false,
        github: false,
      },
    ],
  },
  {
    name: 'Intelligence & Remediation',
    rows: [
      { feature: 'Priority Scoring', fimil: true, sonarqube: true, snyk: true, github: false },
      { feature: 'EPSS Enrichment', fimil: true, sonarqube: false, snyk: true, github: true },
      {
        feature: 'Reachability Analysis',
        fimil: true,
        sonarqube: false,
        snyk: true,
        github: false,
      },
      {
        feature: 'Auto-Triage Rules + Audit Trail',
        fimil: true,
        sonarqube: false,
        snyk: 'Partial',
        github: false,
      },
      { feature: 'Dependency Fix PRs', fimil: true, sonarqube: false, snyk: true, github: true },
      {
        feature: 'Code Fix Suggestions',
        fimil: true,
        sonarqube: 'Partial',
        snyk: true,
        github: true,
      },
      { feature: 'IaC Fix PRs', fimil: true, sonarqube: false, snyk: false, github: false },
      {
        feature: 'PR / Diff-Aware Scanning',
        fimil: true,
        sonarqube: true,
        snyk: true,
        github: true,
      },
      { feature: 'Compliance Mapping', fimil: true, sonarqube: false, snyk: true, github: false },
    ],
  },
  {
    name: 'Deployment & Pricing',
    rows: [
      { feature: 'Cloud (SaaS)', fimil: true, sonarqube: true, snyk: true, github: true },
      { feature: 'Self-Hosted', fimil: true, sonarqube: true, snyk: false, github: 'GHES' },
      {
        feature: 'Air-Gapped Deployment',
        fimil: true,
        sonarqube: true,
        snyk: false,
        github: 'GHES',
      },
      {
        feature: 'Free Tier',
        fimil: true,
        sonarqube: 'Community',
        snyk: true,
        github: 'Public repos',
      },
      {
        feature: 'Open-Source Scanners',
        fimil: true,
        sonarqube: 'Partial',
        snyk: false,
        github: false,
      },
    ],
  },
  {
    name: "Where they're stronger",
    rows: [
      {
        feature: 'Proprietary Vulnerability Research DB',
        fimil: false,
        sonarqube: false,
        snyk: true,
        github: true,
      },
      { feature: 'IDE Plugins', fimil: false, sonarqube: true, snyk: true, github: true },
      {
        feature: 'Code Quality & Maintainability Analysis',
        fimil: false,
        sonarqube: true,
        snyk: false,
        github: false,
      },
      {
        feature: 'First-Party Semantic SAST Engine',
        fimil: 'Via Semgrep',
        sonarqube: true,
        snyk: true,
        github: true,
      },
      {
        feature: 'Native GitHub UI, Zero Setup',
        fimil: false,
        sonarqube: false,
        snyk: false,
        github: true,
      },
      { feature: 'Years in Market', fimil: false, sonarqube: true, snyk: true, github: true },
    ],
  },
];

const summaryCards = [
  { value: '15 scanners + 1 agent', description: 'one signal' },
  { value: 'Every pentest finding', description: 'replay-validated' },
  { value: 'Fixes', description: 'delivered as PRs' },
];

const columns = [
  { key: 'fimil', label: 'Fimil' },
  { key: 'sonarqube', label: 'SonarQube' },
  { key: 'snyk', label: 'Snyk' },
  { key: 'github', label: 'GitHub AS' },
] as const;
---

<BaseLayout
  title="Fimil vs Snyk vs SonarQube vs GitHub Advanced Security (Honest Comparison)"
  description="Side-by-side including where competitors win. Fimil adds what they lack: an exploit-validated AI pentest agent and fixes delivered as pull requests."
  jsonLd={jsonLd}
>
  <Breadcrumbs items={[{ label: 'Compare' }]} />
  <Hero
    headline="How Fimil compares — including where it doesn't win."
    subheadline="The table below marks competitor strengths honestly, because an all-green column is how you know a comparison page is lying. Fimil's bet is different: validated exploits and fixes as PRs, not another findings feed."
  />

  {/* Summary cards */}
  <section class="border-y border-edge bg-panel py-12">
    <div class="mx-auto grid max-w-4xl grid-cols-1 gap-6 px-4 sm:grid-cols-3 sm:px-6 lg:px-8">
      {
        summaryCards.map((card) => (
          <div class="scroll-hidden rounded-xl border border-edge bg-ground p-6 text-center">
            <p class="text-2xl font-bold text-fimil-400">{card.value}</p>
            <p class="mt-1 text-sm text-ink-soft">{card.description}</p>
          </div>
        ))
      }
    </div>
  </section>

  {/* Comparison table */}
  <section class="py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      {/* Desktop table */}
      <div class="hidden overflow-x-auto sm:block">
        <table class="w-full text-left text-sm">
          <thead>
            <tr class="border-b border-edge">
              <th class="py-3 pr-4 font-medium text-ink-faint">Feature</th>
              {
                columns.map((col) => (
                  <th
                    class:list={[
                      'px-4 py-3',
                      col.key === 'fimil'
                        ? 'font-semibold text-fimil-400'
                        : 'font-medium text-ink-faint',
                    ]}
                  >
                    {col.label}
                  </th>
                ))
              }
            </tr>
          </thead>
          <tbody>
            {
              categories.map((category) => (
                <>
                  <tr>
                    <td
                      colspan="5"
                      class="pt-6 pb-2 text-xs font-semibold tracking-wider text-ink-faint uppercase"
                    >
                      {category.name}
                    </td>
                  </tr>
                  {category.rows.map((row) => (
                    <tr class="border-b border-edge">
                      <td class="py-3 pr-4 text-ink">{row.feature}</td>
                      {columns.map((col) => {
                        const value = row[col.key];
                        return (
                          <td class="px-4 py-3">
                            {typeof value === 'string' ? (
                              <span class="text-sm text-ink-soft">{value}</span>
                            ) : value ? (
                              <span class="text-low" aria-label="Yes">
                                &#x2713;
                              </span>
                            ) : (
                              <span class="text-ink-faint" aria-label="No">
                                &mdash;
                              </span>
                            )}
                          </td>
                        );
                      })}
                    </tr>
                  ))}
                </>
              ))
            }
          </tbody>
        </table>
      </div>

      {/* Mobile cards */}
      <div class="space-y-6 sm:hidden">
        {
          categories.map((category) => (
            <div>
              <h3 class="mb-3 text-xs font-semibold tracking-wider text-ink-faint uppercase">
                {category.name}
              </h3>
              <div class="space-y-3">
                {category.rows.map((row) => (
                  <div class="rounded-lg border border-edge bg-panel p-4">
                    <div class="mb-2 font-medium text-ink">{row.feature}</div>
                    <div class="grid grid-cols-2 gap-2 text-sm">
                      {columns.map((col) => {
                        const value = row[col.key];
                        return (
                          <span
                            class:list={[
                              typeof value === 'string'
                                ? 'text-ink-soft'
                                : value
                                  ? 'text-low'
                                  : 'text-ink-faint',
                            ]}
                          >
                            {col.label}: {typeof value === 'string' ? value : value ? 'Yes' : 'No'}
                          </span>
                        );
                      })}
                    </div>
                  </div>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  {/* Why Fimil */}
  <section class="border-t border-edge bg-panel py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold tracking-tight text-ink">Why Fimil anyway</h2>
      <div class="mt-6 space-y-4 text-ink-soft">
        <p>
          Snyk, SonarQube, and GitHub Advanced Security are mature products with real strengths —
          the table above concedes them. What none of them do is close the loop: they hand you a
          list. Fimil <a href="/pentest" class="text-fimil-400 hover:text-fimil-300"
            >validates exploitability with a working reproduction</a
          > and <a href="/platform" class="text-fimil-400 hover:text-fimil-300"
            >opens the pull request that fixes the finding</a
          >.
        </p>
        <p>
          The detection layer is deliberately not proprietary: Fimil orchestrates the best
          open-source scanners — Semgrep, Trivy, Grype, Gitleaks, Checkov, ZAP, Nuclei, Prowler, and
          more — then adds the layers they can't provide alone: cross-tool deduplication,
          correlation, an auditable priority score, and remediation.
        </p>
        <p>
          Compared to an annual manual pentest or PtaaS engagement: Fimil runs on demand, validates
          continuously, and bills per confirmed finding instead of per day of consultant time. It is <em
            >not</em
          > a replacement for human red-teaming on novel business logic — it's the layer that makes sure
          the well-understood vulnerability classes never reach them.
        </p>
        <p>
          And unlike most alternatives, you choose the deployment: <a
            href="/pricing"
            class="text-fimil-400 hover:text-fimil-300"
            data-astro-prefetch="load">cloud or self-hosted</a
          >, including air-gapped. Your source stays ephemeral — cloned, scanned, deleted.
        </p>
      </div>
    </div>
  </section>

  <CTASection
    headline="Ready to replace your patchwork of tools?"
    description="Get early access and see what Fimil can prove against your own staging environment."
    cta={{ label: 'Get early access', href: '/#waitlist' }}
  />
</BaseLayout>
