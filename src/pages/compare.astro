---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/Hero.astro';
import CTASection from '@/components/CTASection.astro';

type ComparisonRow = {
  feature: string;
  fimil: boolean;
  sonarqube: boolean;
  snyk: boolean;
  github: boolean;
};

type ComparisonCategory = {
  name: string;
  rows: ComparisonRow[];
};

const categories: ComparisonCategory[] = [
  {
    name: 'Scanning Coverage',
    rows: [
      { feature: 'SAST', fimil: true, sonarqube: true, snyk: true, github: true },
      { feature: 'SCA', fimil: true, sonarqube: false, snyk: true, github: true },
      { feature: 'Secrets Detection', fimil: true, sonarqube: false, snyk: false, github: true },
      { feature: 'IaC Scanning', fimil: true, sonarqube: false, snyk: true, github: false },
      { feature: 'Container Scanning', fimil: true, sonarqube: false, snyk: true, github: false },
      { feature: 'SBOM Generation', fimil: true, sonarqube: false, snyk: false, github: true },
      {
        feature: 'Multi-Scanner Orchestration',
        fimil: true,
        sonarqube: false,
        snyk: false,
        github: false,
      },
      {
        feature: 'Cross-Tool Deduplication',
        fimil: true,
        sonarqube: false,
        snyk: false,
        github: false,
      },
    ],
  },
  {
    name: 'Intelligence & Prioritization',
    rows: [
      { feature: 'Priority Scoring', fimil: true, sonarqube: true, snyk: true, github: false },
      { feature: 'EPSS Integration', fimil: true, sonarqube: false, snyk: true, github: false },
      {
        feature: 'Reachability Analysis',
        fimil: true,
        sonarqube: false,
        snyk: true,
        github: false,
      },
      { feature: 'Auto-Triage Rules', fimil: true, sonarqube: false, snyk: false, github: false },
      { feature: 'Fix Suggestions', fimil: true, sonarqube: true, snyk: true, github: true },
      { feature: 'PR/Diff Scanning', fimil: true, sonarqube: true, snyk: true, github: true },
      {
        feature: 'Compliance Mapping',
        fimil: true,
        sonarqube: false,
        snyk: true,
        github: false,
      },
    ],
  },
  {
    name: 'Deployment & Pricing',
    rows: [
      { feature: 'Cloud Hosted', fimil: true, sonarqube: false, snyk: true, github: true },
      { feature: 'Self-Hosted Option', fimil: true, sonarqube: true, snyk: false, github: false },
      {
        feature: 'Air-Gapped Support',
        fimil: true,
        sonarqube: true,
        snyk: false,
        github: false,
      },
      { feature: 'Free Tier', fimil: true, sonarqube: true, snyk: true, github: false },
      {
        feature: 'Open Source Scanners',
        fimil: true,
        sonarqube: false,
        snyk: false,
        github: false,
      },
      { feature: 'GitHub Integration', fimil: true, sonarqube: true, snyk: true, github: true },
      { feature: 'GitLab Integration', fimil: true, sonarqube: true, snyk: true, github: false },
      {
        feature: 'Bitbucket Integration',
        fimil: true,
        sonarqube: true,
        snyk: true,
        github: false,
      },
    ],
  },
];

const competitors = ['SonarQube', 'Snyk', 'GitHub AS'] as const;
---

<BaseLayout
  title="Compare — Fimil"
  description="See how Fimil compares to SonarQube, Snyk, and GitHub Advanced Security for application security."
>
  <Hero
    headline="How Fimil Compares"
    subheadline="See how Fimil stacks up against SonarQube, Snyk, and GitHub Advanced Security across scanning coverage, intelligence, and deployment."
  />

  {/* Summary cards */}
  <section
    class="border-b border-gray-200/60 bg-white py-12 dark:border-gray-800/60 dark:bg-gray-950"
  >
    <div class="mx-auto grid max-w-4xl grid-cols-1 gap-6 px-4 sm:grid-cols-3 sm:px-6 lg:px-8">
      <div
        class="reveal rounded-xl border border-fimil-200 bg-fimil-50 p-6 text-center dark:border-fimil-800 dark:bg-fimil-900/20"
      >
        <div class="font-heading text-3xl font-bold text-fimil-600 dark:text-fimil-400">12+</div>
        <div class="text-sm font-medium text-fimil-600 dark:text-fimil-400">Scanners</div>
        <div class="mt-1 text-xs text-gray-500 dark:text-gray-400">1 Dashboard</div>
      </div>
      <div
        class="reveal rounded-xl border border-fimil-200 bg-fimil-50 p-6 text-center dark:border-fimil-800 dark:bg-fimil-900/20"
      >
        <div class="font-heading text-3xl font-bold text-fimil-600 dark:text-fimil-400">90%</div>
        <div class="text-sm font-medium text-fimil-600 dark:text-fimil-400">Noise</div>
        <div class="mt-1 text-xs text-gray-500 dark:text-gray-400">Reduction</div>
      </div>
      <div
        class="reveal rounded-xl border border-fimil-200 bg-fimil-50 p-6 text-center dark:border-fimil-800 dark:bg-fimil-900/20"
      >
        <div class="font-heading text-3xl font-bold text-fimil-600 dark:text-fimil-400">
          Self-Hosted
        </div>
        <div class="mt-1 text-xs text-gray-500 dark:text-gray-400">or Cloud</div>
      </div>
    </div>
  </section>

  {/* Comparison table */}
  <section class="py-20 dark:bg-gray-950">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      {/* Desktop table */}
      <div class="hidden overflow-x-auto sm:block">
        <table class="w-full text-left text-sm">
          <thead>
            <tr class="border-b border-gray-200 dark:border-gray-800">
              <th class="py-3 pr-4 font-medium text-gray-500 dark:text-gray-400">Feature</th>
              <th class="px-4 py-3 font-semibold text-fimil-600 dark:text-fimil-400">Fimil</th>
              {
                competitors.map((c) => (
                  <th class="px-4 py-3 font-medium text-gray-500 dark:text-gray-400">{c}</th>
                ))
              }
            </tr>
          </thead>
          <tbody>
            {
              categories.map((category) => (
                <>
                  <tr>
                    <td
                      colspan="5"
                      class="pt-6 pb-2 font-heading text-xs font-semibold tracking-wider text-gray-400 uppercase dark:text-gray-500"
                    >
                      {category.name}
                    </td>
                  </tr>
                  {category.rows.map((row) => (
                    <tr class="border-b border-gray-100 dark:border-gray-800/50">
                      <td class="py-3 pr-4 text-gray-900 dark:text-white">{row.feature}</td>
                      <td class="px-4 py-3">
                        {row.fimil ? (
                          <span class="text-green-600 dark:text-green-400" aria-label="Yes">
                            &#x2713;
                          </span>
                        ) : (
                          <span class="text-gray-300 dark:text-gray-600" aria-label="No">
                            &mdash;
                          </span>
                        )}
                      </td>
                      <td class="px-4 py-3">
                        {row.sonarqube ? (
                          <span class="text-green-600 dark:text-green-400" aria-label="Yes">
                            &#x2713;
                          </span>
                        ) : (
                          <span class="text-gray-300 dark:text-gray-600" aria-label="No">
                            &mdash;
                          </span>
                        )}
                      </td>
                      <td class="px-4 py-3">
                        {row.snyk ? (
                          <span class="text-green-600 dark:text-green-400" aria-label="Yes">
                            &#x2713;
                          </span>
                        ) : (
                          <span class="text-gray-300 dark:text-gray-600" aria-label="No">
                            &mdash;
                          </span>
                        )}
                      </td>
                      <td class="px-4 py-3">
                        {row.github ? (
                          <span class="text-green-600 dark:text-green-400" aria-label="Yes">
                            &#x2713;
                          </span>
                        ) : (
                          <span class="text-gray-300 dark:text-gray-600" aria-label="No">
                            &mdash;
                          </span>
                        )}
                      </td>
                    </tr>
                  ))}
                </>
              ))
            }
          </tbody>
        </table>
      </div>

      {/* Mobile cards */}
      <div class="space-y-6 sm:hidden">
        {
          categories.map((category) => (
            <div>
              <h3 class="mb-3 font-heading text-xs font-semibold tracking-wider text-gray-400 uppercase dark:text-gray-500">
                {category.name}
              </h3>
              <div class="space-y-3">
                {category.rows.map((row) => (
                  <div class="rounded-lg border border-gray-200 bg-white p-4 dark:border-gray-800 dark:bg-gray-900">
                    <div class="mb-2 font-medium text-gray-900 dark:text-white">{row.feature}</div>
                    <div class="grid grid-cols-2 gap-2 text-sm">
                      <span
                        class:list={[
                          row.fimil ? 'text-green-600 dark:text-green-400' : 'text-gray-400',
                        ]}
                      >
                        Fimil: {row.fimil ? 'Yes' : 'No'}
                      </span>
                      <span
                        class:list={[
                          row.sonarqube ? 'text-green-600 dark:text-green-400' : 'text-gray-400',
                        ]}
                      >
                        SonarQube: {row.sonarqube ? 'Yes' : 'No'}
                      </span>
                      <span
                        class:list={[
                          row.snyk ? 'text-green-600 dark:text-green-400' : 'text-gray-400',
                        ]}
                      >
                        Snyk: {row.snyk ? 'Yes' : 'No'}
                      </span>
                      <span
                        class:list={[
                          row.github ? 'text-green-600 dark:text-green-400' : 'text-gray-400',
                        ]}
                      >
                        GitHub AS: {row.github ? 'Yes' : 'No'}
                      </span>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  {/* Why Fimil */}
  <section
    class="border-t border-gray-200/60 bg-gray-50 py-20 dark:border-gray-800/60 dark:bg-gray-900"
  >
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <h2 class="font-heading text-2xl font-bold tracking-tight text-gray-900 dark:text-white">
        Why Fimil?
      </h2>
      <div class="mt-6 space-y-4 text-gray-600 dark:text-gray-400">
        <p>
          Most security platforms either lock you into proprietary scanners or give you raw output
          from a single tool. Fimil takes a different approach: orchestrate the best open-source
          scanners and unify their output into a single, actionable dashboard.
        </p>
        <p>
          With intelligent cross-tool deduplication, EPSS-based priority scoring, and reachability
          analysis, your team sees only the findings that actually matter &mdash; reducing alert
          fatigue by up to 90%.
        </p>
        <p>
          Deploy Fimil as a cloud-hosted SaaS or self-host it in your own infrastructure. Either
          way, your code is handled ephemerally &mdash; cloned, scanned, and deleted. Never stored,
          never shared, never used for training.
        </p>
      </div>
    </div>
  </section>

  <CTASection
    headline="See the Difference"
    description="Try Fimil free and compare the results yourself."
    cta={{ label: 'Get Started Free', href: 'https://app.fimil.dev/auth/register' }}
  />
</BaseLayout>
