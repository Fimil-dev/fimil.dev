---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import Hero from '@/components/Hero.astro';
import CTASection from '@/components/CTASection.astro';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Fimil vs SonarQube, Snyk, GitHub Advanced Security',
  url: 'https://fimil.dev/compare',
  description:
    'See how Fimil compares to SonarQube, Snyk, and GitHub Advanced Security for application security.',
  about: [
    { '@type': 'SoftwareApplication', name: 'Fimil' },
    { '@type': 'SoftwareApplication', name: 'SonarQube' },
    { '@type': 'SoftwareApplication', name: 'Snyk' },
    { '@type': 'SoftwareApplication', name: 'GitHub Advanced Security' },
  ],
};

type ComparisonRow = {
  feature: string;
  fimil: boolean | string;
  sonarqube: boolean | string;
  snyk: boolean | string;
  github: boolean | string;
};

type ComparisonCategory = {
  name: string;
  rows: ComparisonRow[];
};

const categories: ComparisonCategory[] = [
  {
    name: 'Scanning Coverage',
    rows: [
      { feature: 'SAST', fimil: true, sonarqube: true, snyk: true, github: true },
      {
        feature: 'SCA / Dependency Scanning',
        fimil: true,
        sonarqube: false,
        snyk: true,
        github: true,
      },
      {
        feature: 'Secrets Detection',
        fimil: true,
        sonarqube: false,
        snyk: false,
        github: true,
      },
      { feature: 'IaC Scanning', fimil: true, sonarqube: false, snyk: true, github: false },
      {
        feature: 'Container Image Scanning',
        fimil: true,
        sonarqube: false,
        snyk: true,
        github: false,
      },
      {
        feature: 'SBOM Generation',
        fimil: true,
        sonarqube: false,
        snyk: true,
        github: false,
      },
      {
        feature: 'Multi-Scanner Orchestration',
        fimil: true,
        sonarqube: false,
        snyk: false,
        github: false,
      },
      {
        feature: 'Cross-Tool Deduplication',
        fimil: true,
        sonarqube: false,
        snyk: false,
        github: false,
      },
    ],
  },
  {
    name: 'Intelligence & Prioritization',
    rows: [
      { feature: 'Priority Scoring', fimil: true, sonarqube: true, snyk: true, github: false },
      { feature: 'EPSS Enrichment', fimil: true, sonarqube: false, snyk: true, github: false },
      {
        feature: 'Reachability Analysis',
        fimil: true,
        sonarqube: false,
        snyk: true,
        github: false,
      },
      { feature: 'Auto-Triage Rules', fimil: true, sonarqube: false, snyk: false, github: false },
      { feature: 'Fix Suggestions', fimil: true, sonarqube: true, snyk: true, github: true },
      {
        feature: 'PR / Diff-Aware Scanning',
        fimil: true,
        sonarqube: true,
        snyk: true,
        github: true,
      },
      {
        feature: 'Compliance Mapping',
        fimil: true,
        sonarqube: false,
        snyk: true,
        github: false,
      },
    ],
  },
  {
    name: 'Deployment & Pricing',
    rows: [
      { feature: 'Cloud (SaaS)', fimil: true, sonarqube: true, snyk: true, github: true },
      { feature: 'Self-Hosted', fimil: true, sonarqube: true, snyk: false, github: false },
      {
        feature: 'Air-Gapped Deployment',
        fimil: true,
        sonarqube: true,
        snyk: false,
        github: false,
      },
      {
        feature: 'Free Tier',
        fimil: true,
        sonarqube: 'Community' as string,
        snyk: true,
        github: false,
      },
      {
        feature: 'Open Source Scanners',
        fimil: true,
        sonarqube: 'Partial' as string,
        snyk: false,
        github: false,
      },
      { feature: 'GitHub Integration', fimil: true, sonarqube: true, snyk: true, github: true },
      { feature: 'GitLab Integration', fimil: true, sonarqube: true, snyk: true, github: false },
      {
        feature: 'Bitbucket Integration',
        fimil: true,
        sonarqube: true,
        snyk: true,
        github: false,
      },
    ],
  },
];

const summaryCards = [
  { value: '12+ Scanners', description: '1 Dashboard' },
  { value: '90% Noise', description: 'Reduction' },
  { value: 'Self-Hosted', description: 'or Cloud' },
];

const competitors = ['SonarQube', 'Snyk', 'GitHub Advanced Security'] as const;
---

<BaseLayout
  title="Compare — Fimil"
  description="See how Fimil compares to SonarQube, Snyk, and GitHub Advanced Security for application security."
  jsonLd={jsonLd}
>
  <Breadcrumbs items={[{ label: 'Compare' }]} />
  <Hero
    headline="How Fimil Compares"
    subheadline="Most security platforms are point solutions. Fimil is a unified platform that orchestrates the best open-source scanners and eliminates the noise."
  />

  {/* Summary cards */}
  <section class="border-b border-gray-200 bg-white py-12">
    <div class="mx-auto grid max-w-4xl grid-cols-1 gap-6 px-4 sm:grid-cols-3 sm:px-6 lg:px-8">
      {
        summaryCards.map((card) => (
          <div class="scroll-hidden rounded-xl border border-fimil-200 bg-fimil-50 p-6 text-center">
            <p class="text-2xl font-bold text-fimil-700">{card.value}</p>
            <p class="mt-1 text-sm text-fimil-600">{card.description}</p>
          </div>
        ))
      }
    </div>
  </section>

  {/* Comparison table */}
  <section class="py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      {/* Desktop table */}
      <div class="hidden overflow-x-auto sm:block">
        <table class="w-full text-left text-sm">
          <thead>
            <tr class="border-b border-gray-200">
              <th class="py-3 pr-4 font-medium text-gray-500">Feature</th>
              <th class="px-4 py-3 font-semibold text-fimil-600">Fimil</th>
              {competitors.map((c) => <th class="px-4 py-3 font-medium text-gray-500">{c}</th>)}
            </tr>
          </thead>
          <tbody>
            {
              categories.map((category) => (
                <>
                  <tr>
                    <td
                      colspan="5"
                      class="pt-6 pb-2 text-xs font-semibold tracking-wider text-gray-400 uppercase"
                    >
                      {category.name}
                    </td>
                  </tr>
                  {category.rows.map((row) => (
                    <tr class="border-b border-gray-100">
                      <td class="py-3 pr-4 text-gray-900">{row.feature}</td>
                      <td class="px-4 py-3">
                        {typeof row.fimil === 'string' ? (
                          <span class="text-sm text-gray-700">{row.fimil}</span>
                        ) : row.fimil ? (
                          <span class="text-green-600" aria-label="Yes">
                            &#x2713;
                          </span>
                        ) : (
                          <span class="text-gray-300" aria-label="No">
                            &mdash;
                          </span>
                        )}
                      </td>
                      <td class="px-4 py-3">
                        {typeof row.sonarqube === 'string' ? (
                          <span class="text-sm text-gray-700">{row.sonarqube}</span>
                        ) : row.sonarqube ? (
                          <span class="text-green-600" aria-label="Yes">
                            &#x2713;
                          </span>
                        ) : (
                          <span class="text-gray-300" aria-label="No">
                            &mdash;
                          </span>
                        )}
                      </td>
                      <td class="px-4 py-3">
                        {typeof row.snyk === 'string' ? (
                          <span class="text-sm text-gray-700">{row.snyk}</span>
                        ) : row.snyk ? (
                          <span class="text-green-600" aria-label="Yes">
                            &#x2713;
                          </span>
                        ) : (
                          <span class="text-gray-300" aria-label="No">
                            &mdash;
                          </span>
                        )}
                      </td>
                      <td class="px-4 py-3">
                        {typeof row.github === 'string' ? (
                          <span class="text-sm text-gray-700">{row.github}</span>
                        ) : row.github ? (
                          <span class="text-green-600" aria-label="Yes">
                            &#x2713;
                          </span>
                        ) : (
                          <span class="text-gray-300" aria-label="No">
                            &mdash;
                          </span>
                        )}
                      </td>
                    </tr>
                  ))}
                </>
              ))
            }
          </tbody>
        </table>
      </div>

      {/* Mobile cards */}
      <div class="space-y-6 sm:hidden">
        {
          categories.map((category) => (
            <div>
              <h3 class="mb-3 text-xs font-semibold tracking-wider text-gray-400 uppercase">
                {category.name}
              </h3>
              <div class="space-y-3">
                {category.rows.map((row) => (
                  <div class="rounded-lg border border-gray-200 bg-white p-4">
                    <div class="mb-2 font-medium text-gray-900">{row.feature}</div>
                    <div class="grid grid-cols-2 gap-2 text-sm">
                      <span
                        class:list={[
                          typeof row.fimil === 'string'
                            ? 'text-gray-700'
                            : row.fimil
                              ? 'text-green-600'
                              : 'text-gray-400',
                        ]}
                      >
                        Fimil:{' '}
                        {typeof row.fimil === 'string' ? row.fimil : row.fimil ? 'Yes' : 'No'}
                      </span>
                      <span
                        class:list={[
                          typeof row.sonarqube === 'string'
                            ? 'text-gray-700'
                            : row.sonarqube
                              ? 'text-green-600'
                              : 'text-gray-400',
                        ]}
                      >
                        SonarQube:{' '}
                        {typeof row.sonarqube === 'string'
                          ? row.sonarqube
                          : row.sonarqube
                            ? 'Yes'
                            : 'No'}
                      </span>
                      <span
                        class:list={[
                          typeof row.snyk === 'string'
                            ? 'text-gray-700'
                            : row.snyk
                              ? 'text-green-600'
                              : 'text-gray-400',
                        ]}
                      >
                        Snyk: {typeof row.snyk === 'string' ? row.snyk : row.snyk ? 'Yes' : 'No'}
                      </span>
                      <span
                        class:list={[
                          typeof row.github === 'string'
                            ? 'text-gray-700'
                            : row.github
                              ? 'text-green-600'
                              : 'text-gray-400',
                        ]}
                      >
                        GitHub AS:{' '}
                        {typeof row.github === 'string' ? row.github : row.github ? 'Yes' : 'No'}
                      </span>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  {/* Why Fimil */}
  <section class="border-t border-gray-200 bg-gray-50 py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold tracking-tight text-gray-900">Why Fimil</h2>
      <div class="mt-6 space-y-4 text-gray-600">
        <p>
          Other platforms build their own proprietary scanners. Fimil takes a different approach: we
          <a href="/features" class="text-fimil-600 hover:text-fimil-700"
            >orchestrate the best open-source tools</a
          > the security community has already built. This means you get best-in-class detection without
          vendor lock-in.
        </p>
        <p>
          The real problem isn't finding vulnerabilities &mdash; it's finding the right ones.
          Running 12 scanners produces thousands of overlapping results. Fimil deduplicates across
          tools, enriches with EPSS data, analyzes reachability, and surfaces only the findings that
          actually matter.
        </p>
        <p>
          And unlike most alternatives, Fimil gives you the choice: run it as a <a
            href="/pricing"
            class="text-fimil-600 hover:text-fimil-700"
            data-astro-prefetch="load">cloud service</a
          > or deploy on your own infrastructure. Your source code stays ephemeral &mdash; cloned, scanned,
          deleted. Never persisted, never shared.
        </p>
      </div>
    </div>
  </section>

  <CTASection
    headline="Ready to Replace Your Patchwork of Tools?"
    description="Join the waitlist or schedule a demo to see Fimil in action."
    cta={{ label: 'Join Waitlist', href: '/#waitlist' }}
  />
</BaseLayout>
