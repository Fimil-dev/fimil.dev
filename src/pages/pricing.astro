---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PricingCard from '@/components/PricingCard.astro';
import CTASection from '@/components/CTASection.astro';

const plans = [
  {
    name: 'Free',
    price: 0,
    description: 'For individual developers getting started with security',
    features: [
      '3 repositories',
      '10 scans per month',
      'All scanner types',
      'Email notifications',
      '7-day scan history',
      'Community support',
    ],
    cta: { label: 'Join Waitlist', href: '/#waitlist' },
  },
  {
    name: 'Team',
    price: 49,
    description: 'For growing teams that need more power',
    features: [
      '10 repositories',
      '100 scans per month',
      '5 team members',
      'Slack notifications',
      'API access',
      'SBOM export',
      '30-day scan history',
      'Email support',
    ],
    cta: { label: 'Join Waitlist', href: '/#waitlist' },
    highlighted: true,
  },
  {
    name: 'Business',
    price: 199,
    description: 'For organizations with advanced security needs',
    features: [
      '50 repositories',
      '500 scans per month',
      '25 team members',
      'Scanner profiles',
      'Auto-triage rules',
      'Scan policies',
      'Priority scoring',
      '90-day scan history',
      'Priority support',
    ],
    cta: { label: 'Join Waitlist', href: '/#waitlist' },
  },
  {
    name: 'Enterprise',
    price: 'Custom' as const,
    period: '',
    description: 'For enterprises with custom requirements',
    features: [
      'Unlimited repositories',
      'Unlimited scans',
      'Unlimited team members',
      'Self-hosted deployment',
      'SSO/SAML',
      'Custom integrations',
      'Unlimited history',
      'Dedicated support',
      'SLA guarantee',
    ],
    cta: { label: 'Contact Sales', href: '/contact' },
  },
];

type CellValue = string | boolean;
interface ComparisonRow {
  feature: string;
  free: CellValue;
  team: CellValue;
  business: CellValue;
  enterprise: CellValue;
}

const comparisonData: ComparisonRow[] = [
  { feature: 'Repositories', free: '3', team: '10', business: '50', enterprise: 'Unlimited' },
  {
    feature: 'Scans per month',
    free: '10',
    team: '100',
    business: '500',
    enterprise: 'Unlimited',
  },
  {
    feature: 'Team members',
    free: '1',
    team: '5',
    business: '25',
    enterprise: 'Unlimited',
  },
  { feature: 'SAST scanning', free: true, team: true, business: true, enterprise: true },
  { feature: 'SCA scanning', free: true, team: true, business: true, enterprise: true },
  { feature: 'Secrets detection', free: true, team: true, business: true, enterprise: true },
  { feature: 'IaC scanning', free: true, team: true, business: true, enterprise: true },
  { feature: 'Container scanning', free: true, team: true, business: true, enterprise: true },
  { feature: 'GitHub integration', free: true, team: true, business: true, enterprise: true },
  { feature: 'GitLab integration', free: true, team: true, business: true, enterprise: true },
  { feature: 'Bitbucket integration', free: true, team: true, business: true, enterprise: true },
  { feature: 'Email notifications', free: true, team: true, business: true, enterprise: true },
  { feature: 'Slack notifications', free: false, team: true, business: true, enterprise: true },
  { feature: 'API access', free: false, team: true, business: true, enterprise: true },
  { feature: 'SBOM export', free: false, team: true, business: true, enterprise: true },
  { feature: 'Scanner profiles', free: false, team: false, business: true, enterprise: true },
  { feature: 'Auto-triage rules', free: false, team: false, business: true, enterprise: true },
  { feature: 'Scan policies', free: false, team: false, business: true, enterprise: true },
  { feature: 'Priority scoring', free: false, team: false, business: true, enterprise: true },
  { feature: 'EPSS enrichment', free: false, team: false, business: true, enterprise: true },
  { feature: 'Self-hosted option', free: false, team: false, business: false, enterprise: true },
  { feature: 'SSO/SAML', free: false, team: false, business: false, enterprise: true },
  { feature: 'Custom integrations', free: false, team: false, business: false, enterprise: true },
  { feature: 'SLA guarantee', free: false, team: false, business: false, enterprise: true },
];

const planKeys = ['free', 'team', 'business', 'enterprise'] as const;
const planLabels = ['Free', 'Team', 'Business', 'Enterprise'];

const faqs = [
  {
    q: 'Can I switch plans at any time?',
    a: "Yes! You can upgrade or downgrade at any time. Changes take effect immediately, and we'll prorate the difference.",
  },
  {
    q: 'What payment methods do you accept?',
    a: 'We accept all major credit cards through Stripe. Enterprise customers can pay via invoice with NET-30 terms.',
  },
  {
    q: 'Is there a free trial?',
    a: 'The Free plan is available indefinitely with no credit card required. Paid plans include a 14-day free trial.',
  },
  {
    q: 'What happens if I exceed my limits?',
    a: "You'll receive a notification at 80% usage. If you hit the limit, additional scans will be queued until the next billing cycle. You can upgrade anytime.",
  },
  {
    q: 'Can I self-host Fimil?',
    a: 'Yes! The Enterprise plan includes our Kubernetes operator for on-premises deployment. We also support air-gapped installations.',
  },
  {
    q: 'Do you offer discounts for startups or open source?',
    a: 'Yes! We offer special pricing for startups, non-profits, and open-source projects. Contact sales@fimil.dev for details.',
  },
  {
    q: 'Where does my source code go?',
    a: 'Nowhere. Scanners run in ephemeral containers with no network access. Your source code is cloned, scanned, and immediately deleted. We never store your code.',
  },
  {
    q: 'Can I run Fimil in an air-gapped environment?',
    a: 'Yes, the Enterprise plan supports fully air-gapped deployments with offline scanner images and no external connectivity required.',
  },
  {
    q: 'What compliance frameworks do you support?',
    a: "Fimil's Checkov integration maps findings to CIS Benchmarks, SOC 2, PCI DSS, HIPAA, and NIST 800-53 controls. We're continuously adding more framework mappings.",
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.q,
    acceptedAnswer: { '@type': 'Answer', text: faq.a },
  })),
};
---

<BaseLayout
  title="Pricing — Free, Team, Business & Enterprise Plans | Fimil"
  description="Start free with 3 repos and 10 scans/month. Team ($49/mo), Business ($199/mo), and Enterprise plans with self-hosted deployment. All scanner types included on every plan."
  jsonLd={jsonLd}
>
  {/* Header */}
  <section class="bg-gradient-to-b from-fimil-50 to-white py-16 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <h1 class="text-4xl font-bold tracking-tight text-gray-900 sm:text-5xl">
          Simple, Transparent Pricing
        </h1>
        <p class="mt-6 text-lg text-gray-600">
          Start free, scale as you grow. No hidden fees, no surprises.
        </p>
      </div>
    </div>
  </section>

  {/* Pricing cards */}
  <section class="py-16 sm:py-24">
    <div class="mx-auto grid max-w-7xl gap-8 px-4 sm:grid-cols-2 sm:px-6 lg:grid-cols-4 lg:px-8">
      {
        plans.map((plan) => (
          <PricingCard
            name={plan.name}
            price={plan.price}
            period={plan.period}
            description={plan.description}
            features={plan.features}
            cta={plan.cta}
            highlighted={plan.highlighted}
          />
        ))
      }
    </div>
  </section>

  {/* Feature Comparison Table */}
  <section class="bg-gray-50 py-16 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-center text-2xl font-bold text-gray-900 sm:text-3xl">Feature Comparison</h2>

      {/* Desktop table */}
      <div class="mt-12 hidden overflow-x-auto sm:block">
        <table class="w-full min-w-[640px]">
          <thead>
            <tr class="border-b border-gray-200">
              <th class="py-4 text-left text-sm font-semibold text-gray-900">Feature</th>
              <th class="px-4 py-4 text-center text-sm font-semibold text-gray-900">Free</th>
              <th class="px-4 py-4 text-center text-sm font-semibold text-fimil-600">Team</th>
              <th class="px-4 py-4 text-center text-sm font-semibold text-gray-900">Business</th>
              <th class="px-4 py-4 text-center text-sm font-semibold text-gray-900">Enterprise</th>
            </tr>
          </thead>
          <tbody>
            {
              comparisonData.map((row, index) => (
                <tr class={index % 2 === 0 ? 'bg-white' : 'bg-gray-50'}>
                  <td class="py-3 text-sm text-gray-600">{row.feature}</td>
                  {planKeys.map((key) => (
                    <td class="px-4 py-3 text-center">
                      {typeof row[key] === 'boolean' ? (
                        row[key] ? (
                          <svg
                            class="mx-auto h-5 w-5 text-green-500"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                          >
                            <path
                              stroke-linecap="round"
                              stroke-linejoin="round"
                              d="M5 13l4 4L19 7"
                            />
                          </svg>
                        ) : (
                          <svg
                            class="mx-auto h-5 w-5 text-gray-300"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                          >
                            <path
                              stroke-linecap="round"
                              stroke-linejoin="round"
                              d="M6 18L18 6M6 6l12 12"
                            />
                          </svg>
                        )
                      ) : (
                        <span class="text-sm text-gray-900">{row[key]}</span>
                      )}
                    </td>
                  ))}
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>

      {/* Mobile plan selector */}
      <div class="mt-12 sm:hidden">
        <div class="flex rounded-lg border border-gray-200 bg-white p-1" role="tablist">
          {
            planLabels.map((label, i) => (
              <button
                class="comparison-tab flex-1 rounded-md px-2 py-2 text-xs font-medium text-gray-600 transition-colors hover:text-gray-900"
                data-tab-index={i}
                role="tab"
                aria-selected={i === 0 ? 'true' : 'false'}
              >
                {label}
              </button>
            ))
          }
        </div>
        <div class="mt-4">
          {
            planKeys.map((key, i) => (
              <div
                class:list={['comparison-panel space-y-1', i === 0 ? '' : 'hidden']}
                data-panel-index={i}
                role="tabpanel"
              >
                {comparisonData.map((row, index) => (
                  <div
                    class={`flex items-center justify-between rounded px-3 py-2.5 ${
                      index % 2 === 0 ? 'bg-white' : 'bg-gray-50'
                    }`}
                  >
                    <span class="text-sm text-gray-600">{row.feature}</span>
                    <span class="text-sm">
                      {typeof row[key] === 'boolean' ? (
                        row[key] ? (
                          <svg
                            class="h-5 w-5 text-green-500"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                          >
                            <path
                              stroke-linecap="round"
                              stroke-linejoin="round"
                              d="M5 13l4 4L19 7"
                            />
                          </svg>
                        ) : (
                          <svg
                            class="h-5 w-5 text-gray-300"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                          >
                            <path
                              stroke-linecap="round"
                              stroke-linejoin="round"
                              d="M6 18L18 6M6 6l12 12"
                            />
                          </svg>
                        )
                      ) : (
                        <span class="font-medium text-gray-900">{row[key]}</span>
                      )}
                    </span>
                  </div>
                ))}
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  {/* FAQ */}
  <section class="py-16 sm:py-24">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-center text-2xl font-bold text-gray-900 sm:text-3xl">
        Frequently Asked Questions
      </h2>
      <div class="mt-12 space-y-4">
        {
          faqs.map((faq) => (
            <details class="group rounded-lg border border-gray-200 bg-white">
              <summary class="flex cursor-pointer items-center justify-between px-6 py-4 text-sm font-semibold text-gray-900">
                {faq.q}
                <svg
                  class="h-5 w-5 shrink-0 text-gray-400 transition-transform group-open:rotate-180"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </summary>
              <div class="px-6 pb-4 text-sm text-gray-600">{faq.a}</div>
            </details>
          ))
        }
      </div>
    </div>
  </section>

  {/* Enterprise CTA */}
  <CTASection
    headline="Need Self-Hosted Deployment?"
    description="Fimil Enterprise gives you full control with on-premises or air-gapped installations."
    cta={{ label: 'Contact Sales', href: '/contact' }}
  />
</BaseLayout>

<script is:inline>
  (function () {
    const tabs = document.querySelectorAll('.comparison-tab');
    const panels = document.querySelectorAll('.comparison-panel');
    if (!tabs.length) return;

    tabs.forEach(function (tab) {
      tab.addEventListener('click', function () {
        const index = parseInt(tab.getAttribute('data-tab-index') || '0', 10);

        tabs.forEach(function (t) {
          t.classList.remove('bg-white', 'text-gray-900', 'shadow-sm');
          t.classList.add('text-gray-600');
          t.setAttribute('aria-selected', 'false');
        });
        tab.classList.add('bg-white', 'text-gray-900', 'shadow-sm');
        tab.classList.remove('text-gray-600');
        tab.setAttribute('aria-selected', 'true');

        panels.forEach(function (p) {
          p.classList.add('hidden');
        });
        const activePanel = document.querySelector('[data-panel-index="' + index + '"]');
        if (activePanel) activePanel.classList.remove('hidden');
      });
    });

    /* Activate the first tab on load */
    const firstTab = tabs[0];
    if (firstTab) {
      firstTab.classList.add('bg-white', 'text-gray-900', 'shadow-sm');
      firstTab.classList.remove('text-gray-600');
    }
  })();
</script>
