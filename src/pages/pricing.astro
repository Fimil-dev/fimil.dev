---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import PricingCard from '@/components/PricingCard.astro';
import CTASection from '@/components/CTASection.astro';
import Section from '@/components/Section.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import MockupWindow from '@/components/MockupWindow.astro';
import Icon from '@/components/Icon.astro';

// Tier limits and features mirror the billing source of truth:
// fimil/api/src/fimil/billing/plan_limits.py
const plans = [
  {
    name: 'Free',
    price: 0,
    period: 'month',
    description: 'For individual developers getting started with security',
    features: ['3 repositories', '10 scans per month', '1 user', 'Email notifications'],
    cta: { label: 'Get early access', href: '/#waitlist' },
  },
  {
    name: 'Team',
    price: 49,
    period: 'month',
    description: 'For growing teams that need more power',
    features: [
      '10 repositories',
      '100 scans per month',
      '5 team members',
      'Slack notifications',
      'API access',
      'SBOM export',
      'AI security intelligence',
      'AI Pentest add-on available',
    ],
    cta: { label: 'Get early access', href: '/#waitlist' },
    highlighted: true,
  },
  {
    name: 'Business',
    price: 199,
    period: 'month',
    description: 'For organizations with advanced security needs',
    features: [
      '50 repositories',
      '500 scans per month',
      '25 team members',
      'Scanner profiles',
      'Custom scan policies',
      'Auto-triage rules',
      'Auto-fix PRs',
      'AI Pentest add-on available',
      'Priority support',
    ],
    cta: { label: 'Get early access', href: '/#waitlist' },
  },
  {
    name: 'Enterprise',
    price: 'Custom' as const,
    period: '',
    description: 'For enterprises with custom requirements',
    features: [
      'Unlimited repositories',
      'Unlimited scans',
      'Unlimited team members',
      'Self-hosted deployment',
      'SSO/SAML',
      'Custom integrations',
      'Dedicated support',
    ],
    cta: { label: 'Contact Sales', href: '/contact' },
  },
];

type CellValue = string | boolean;
interface ComparisonRow {
  feature: string;
  free: CellValue;
  team: CellValue;
  business: CellValue;
  enterprise: CellValue;
}

const comparisonData: ComparisonRow[] = [
  { feature: 'Repositories', free: '3', team: '10', business: '50', enterprise: 'Unlimited' },
  {
    feature: 'Scans per month',
    free: '10',
    team: '100',
    business: '500',
    enterprise: 'Unlimited',
  },
  {
    feature: 'Team members',
    free: '1',
    team: '5',
    business: '25',
    enterprise: 'Unlimited',
  },
  { feature: 'SAST scanning', free: true, team: true, business: true, enterprise: true },
  { feature: 'SCA scanning', free: true, team: true, business: true, enterprise: true },
  { feature: 'Secrets detection', free: true, team: true, business: true, enterprise: true },
  { feature: 'IaC scanning', free: true, team: true, business: true, enterprise: true },
  { feature: 'Container scanning', free: true, team: true, business: true, enterprise: true },
  { feature: 'DAST scanning', free: true, team: true, business: true, enterprise: true },
  { feature: 'CSPM (cloud accounts)', free: true, team: true, business: true, enterprise: true },
  { feature: 'Priority scoring & EPSS', free: true, team: true, business: true, enterprise: true },
  { feature: 'GitHub integration', free: true, team: true, business: true, enterprise: true },
  { feature: 'GitLab integration', free: true, team: true, business: true, enterprise: true },
  { feature: 'Bitbucket integration', free: true, team: true, business: true, enterprise: true },
  { feature: 'Email notifications', free: true, team: true, business: true, enterprise: true },
  { feature: 'Slack notifications', free: false, team: true, business: true, enterprise: true },
  { feature: 'API access & CLI', free: false, team: true, business: true, enterprise: true },
  { feature: 'MCP server', free: false, team: true, business: true, enterprise: true },
  { feature: 'SBOM export', free: false, team: true, business: true, enterprise: true },
  {
    feature: 'AI Pentest (usage-based)',
    free: false,
    team: 'Add-on',
    business: 'Add-on',
    enterprise: 'Add-on',
  },
  { feature: 'Scanner profiles', free: false, team: false, business: true, enterprise: true },
  { feature: 'Auto-triage rules', free: false, team: false, business: true, enterprise: true },
  { feature: 'Custom scan policies', free: false, team: false, business: true, enterprise: true },
  { feature: 'Auto-fix PRs', free: false, team: false, business: true, enterprise: true },
  { feature: 'Self-hosted option', free: false, team: false, business: false, enterprise: true },
  { feature: 'Kubernetes operator', free: false, team: false, business: false, enterprise: true },
  { feature: 'SSO/SAML', free: false, team: false, business: false, enterprise: true },
  { feature: 'Custom integrations', free: false, team: false, business: false, enterprise: true },
];

const planKeys = ['free', 'team', 'business', 'enterprise'] as const;
const planLabels = ['Free', 'Team', 'Business', 'Enterprise'];

const faqs = [
  {
    q: 'How is AI Pentest billed?',
    a: 'Usage-based, on paid plans: you pay per confirmed finding. If a confirmed finding is later overturned as a false positive, the charge is automatically reversed and credited. The kill switch is always free.',
  },
  {
    q: 'What is a “confirmed” finding?',
    a: 'Before any pentest finding is reported, a validator replays the exploit against your target. Only findings that reproduce are confirmed — and only confirmed findings are billed.',
  },
  {
    q: 'Is the pentest agent safe to run against my environments?',
    a: 'The agent runs inside a scope guard: hostname allowlist, destructive-verb gating, rate limits, DNS pinning, and a continuously-checked kill switch. We recommend starting with staging. See the AI Pentest page for the full containment model.',
  },
  {
    q: 'Can I switch plans at any time?',
    a: "Yes! You can upgrade or downgrade at any time. Changes take effect immediately, and we'll prorate the difference.",
  },
  {
    q: 'What payment methods do you accept?',
    a: 'We accept all major credit cards through Stripe. Enterprise customers can pay via invoice with NET-30 terms.',
  },
  {
    q: 'Is there a free trial?',
    a: 'The Free plan is available indefinitely with no credit card required — use it to evaluate the platform on real repos before upgrading.',
  },
  {
    q: 'What happens if I exceed my limits?',
    a: "You'll receive a notification as you approach your limits, with a grace period before anything is blocked. You can upgrade anytime.",
  },
  {
    q: 'Can I self-host Fimil?',
    a: 'Yes! The Enterprise plan includes our Kubernetes operator for on-premises deployment. We also support air-gapped installations.',
  },
  {
    q: 'Do you offer discounts for startups or open source?',
    a: 'Yes! We offer special pricing for startups, non-profits, and open-source projects. Contact sales@fimil.dev for details.',
  },
  {
    q: 'Where does my source code go?',
    a: 'Scanners run in isolated, ephemeral environments: your source is cloned for the scan and deleted when it completes. Fimil stores findings and metadata — not your code.',
  },
  {
    q: 'Can I run Fimil in an air-gapped environment?',
    a: 'Yes, the Enterprise plan supports fully air-gapped deployments with offline scanner images and no external connectivity required.',
  },
  {
    q: 'What compliance frameworks do you support?',
    a: 'Findings map to CIS Benchmarks, SOC 2, PCI DSS, HIPAA, and ISO 27001 controls — including per-vector mappings on AI Pentest findings — for use as audit evidence.',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.q,
    acceptedAnswer: { '@type': 'Answer', text: faq.a },
  })),
};
---

<BaseLayout
  title="Pricing — Free, Team $49, Business $199, Enterprise | Fimil"
  description="Start free with 3 repos. AI Pentest is usage-based on paid plans — pay per confirmed finding, false positives credited. Self-hosted available on Enterprise."
  jsonLd={jsonLd}
>
  <Breadcrumbs items={[{ label: 'Pricing' }]} />
  {/* Header */}
  <section class="relative overflow-hidden py-16 sm:py-24">
    <div class="bg-grid absolute inset-0" aria-hidden="true"></div>
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <h1 class="text-4xl font-bold tracking-tight text-ink sm:text-5xl">
          Pricing that matches how you scan.
        </h1>
        <p class="mt-6 text-lg text-ink-soft">
          Start free, scale as you grow. AI Pentest is usage-based — billed on proof, not noise.
        </p>
      </div>
    </div>
  </section>

  {/* Pricing cards */}
  <section class="py-16 sm:py-24">
    <div class="mx-auto grid max-w-7xl gap-8 px-4 sm:grid-cols-2 sm:px-6 lg:grid-cols-4 lg:px-8">
      {
        plans.map((plan) => (
          <PricingCard
            name={plan.name}
            price={plan.price}
            period={plan.period}
            description={plan.description}
            features={plan.features}
            cta={plan.cta}
            highlighted={plan.highlighted}
          />
        ))
      }
    </div>
  </section>

  {/* AI Pentest add-on */}
  <Section variant="panel">
    <SectionHeading
      eyebrow="add-on"
      title="AI Pentest: pay per confirmed finding."
      lead="Available on paid plans. Metered per confirmed finding — never per scan, never per hour. If the validator's confirmation is later overturned as a false positive, the charge reverses and credits automatically."
    />
    <div class="mx-auto flex max-w-5xl flex-col items-center gap-10 lg:flex-row">
      <div class="grid flex-1 gap-4 sm:grid-cols-3 lg:grid-cols-1">
        <div class="rounded-xl border border-edge bg-ground p-5">
          <Icon name="shield-check" class="h-5 w-5 text-fimil-400" />
          <h3 class="mt-3 text-base font-semibold text-ink">Billed on proof, not noise</h3>
          <p class="mt-1.5 text-sm text-ink-soft">
            Only replay-validated findings meter. Unconfirmed candidates never surface, never bill.
          </p>
        </div>
        <div class="rounded-xl border border-edge bg-ground p-5">
          <Icon name="git-merge" class="h-5 w-5 text-fimil-400" />
          <h3 class="mt-3 text-base font-semibold text-ink">False positives credited</h3>
          <p class="mt-1.5 text-sm text-ink-soft">
            Overturn a finding and the meter event reverses — automatically, no support ticket.
          </p>
        </div>
        <div class="rounded-xl border border-edge bg-ground p-5">
          <Icon name="zap" class="h-5 w-5 text-fimil-400" />
          <h3 class="mt-3 text-base font-semibold text-ink">Kill switch always free</h3>
          <p class="mt-1.5 text-sm text-ink-soft">
            Halt a run at any moment. Safety controls are never metered.
          </p>
        </div>
      </div>
      <div class="w-full max-w-md flex-1">
        <MockupWindow title="usage — June 2026" variant="plain">
          <div class="border-b border-edge px-4 py-2.5 font-mono text-xs text-ink-faint">
            usage — June 2026
          </div>
          <div class="space-y-2 px-4 py-3 font-mono text-[12px]">
            <div class="flex items-center justify-between gap-2">
              <span class="truncate text-ink-soft">
                <span class="badge-low mr-2">confirmed</span>IDOR /api/v1/orders
              </span>
              <span class="shrink-0 text-ink">+1</span>
            </div>
            <div class="flex items-center justify-between gap-2">
              <span class="truncate text-ink-soft">
                <span class="badge-low mr-2">confirmed</span>SQLi /search
              </span>
              <span class="shrink-0 text-ink">+1</span>
            </div>
            <div class="flex items-center justify-between gap-2">
              <span class="truncate text-ink-soft">
                <span class="badge-medium mr-2">reversed</span>XSS /profile · FP
              </span>
              <span class="shrink-0 text-low">−1 credited</span>
            </div>
            <div class="flex items-center justify-between gap-2 border-t border-edge pt-2">
              <span class="text-ink-faint">billable findings</span>
              <span class="shrink-0 text-ink">2</span>
            </div>
          </div>
        </MockupWindow>
        <p class="mt-3 text-center text-xs text-ink-faint">
          Per-finding rates shown in-app during early access.
        </p>
      </div>
    </div>
  </Section>

  {/* Feature Comparison Table */}
  <section class="py-16 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-center text-2xl font-bold text-ink sm:text-3xl">Feature Comparison</h2>

      {/* Desktop table */}
      <div class="mt-12 hidden overflow-x-auto sm:block">
        <table class="w-full min-w-[640px]">
          <thead>
            <tr class="border-b border-edge">
              <th class="py-4 text-left text-sm font-semibold text-ink">Feature</th>
              <th class="px-4 py-4 text-center text-sm font-semibold text-ink">Free</th>
              <th class="px-4 py-4 text-center text-sm font-semibold text-fimil-400">Team</th>
              <th class="px-4 py-4 text-center text-sm font-semibold text-ink">Business</th>
              <th class="px-4 py-4 text-center text-sm font-semibold text-ink">Enterprise</th>
            </tr>
          </thead>
          <tbody>
            {
              comparisonData.map((row, index) => (
                <tr class={index % 2 === 0 ? 'bg-ground' : 'bg-panel'}>
                  <td class="py-3 text-sm text-ink-soft">{row.feature}</td>
                  {planKeys.map((key) => (
                    <td class="px-4 py-3 text-center">
                      {typeof row[key] === 'boolean' ? (
                        row[key] ? (
                          <svg
                            class="mx-auto h-5 w-5 text-low"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                          >
                            <path
                              stroke-linecap="round"
                              stroke-linejoin="round"
                              d="M5 13l4 4L19 7"
                            />
                          </svg>
                        ) : (
                          <svg
                            class="mx-auto h-5 w-5 text-edge-bright"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                          >
                            <path
                              stroke-linecap="round"
                              stroke-linejoin="round"
                              d="M6 18L18 6M6 6l12 12"
                            />
                          </svg>
                        )
                      ) : (
                        <span class="text-sm text-ink">{row[key]}</span>
                      )}
                    </td>
                  ))}
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>

      {/* Mobile plan selector */}
      <div class="mt-12 sm:hidden">
        <div class="flex rounded-lg border border-edge bg-panel p-1" role="tablist">
          {
            planLabels.map((label, i) => (
              <button
                class="comparison-tab flex-1 rounded-md px-2 py-2 text-xs font-medium text-ink-soft transition-colors hover:text-ink"
                data-tab-index={i}
                role="tab"
                aria-selected={i === 0 ? 'true' : 'false'}
              >
                {label}
              </button>
            ))
          }
        </div>
        <div class="mt-4">
          {
            planKeys.map((key, i) => (
              <div
                class:list={['comparison-panel space-y-1', i === 0 ? '' : 'hidden']}
                data-panel-index={i}
                role="tabpanel"
              >
                {comparisonData.map((row, index) => (
                  <div
                    class={`flex items-center justify-between rounded px-3 py-2.5 ${
                      index % 2 === 0 ? 'bg-ground' : 'bg-panel'
                    }`}
                  >
                    <span class="text-sm text-ink-soft">{row.feature}</span>
                    <span class="text-sm">
                      {typeof row[key] === 'boolean' ? (
                        row[key] ? (
                          <svg
                            class="h-5 w-5 text-low"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                          >
                            <path
                              stroke-linecap="round"
                              stroke-linejoin="round"
                              d="M5 13l4 4L19 7"
                            />
                          </svg>
                        ) : (
                          <svg
                            class="h-5 w-5 text-edge-bright"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                          >
                            <path
                              stroke-linecap="round"
                              stroke-linejoin="round"
                              d="M6 18L18 6M6 6l12 12"
                            />
                          </svg>
                        )
                      ) : (
                        <span class="font-medium text-ink">{row[key]}</span>
                      )}
                    </span>
                  </div>
                ))}
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  {/* FAQ */}
  <section class="border-t border-edge bg-panel py-16 sm:py-24">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-center text-2xl font-bold text-ink sm:text-3xl">
        Frequently Asked Questions
      </h2>
      <div class="mt-12 space-y-4">
        {
          faqs.map((faq) => (
            <details class="group rounded-lg border border-edge bg-ground">
              <summary class="flex cursor-pointer items-center justify-between px-6 py-4 text-sm font-semibold text-ink">
                {faq.q}
                <svg
                  class="h-5 w-5 shrink-0 text-ink-faint transition-transform group-open:rotate-180"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </summary>
              <div class="px-6 pb-4 text-sm text-ink-soft">{faq.a}</div>
            </details>
          ))
        }
      </div>
    </div>
  </section>

  {/* Enterprise CTA */}
  <CTASection
    headline="Need Self-Hosted Deployment?"
    description="Fimil Enterprise gives you full control with on-premises or air-gapped installations."
    cta={{ label: 'Contact Sales', href: '/contact' }}
  />
</BaseLayout>

<script is:inline>
  (function () {
    const tabs = document.querySelectorAll('.comparison-tab');
    const panels = document.querySelectorAll('.comparison-panel');
    if (!tabs.length) return;

    tabs.forEach(function (tab) {
      tab.addEventListener('click', function () {
        const index = parseInt(tab.getAttribute('data-tab-index') || '0', 10);

        tabs.forEach(function (t) {
          t.classList.remove('bg-raised', 'text-ink');
          t.classList.add('text-ink-soft');
          t.setAttribute('aria-selected', 'false');
        });
        tab.classList.add('bg-raised', 'text-ink');
        tab.classList.remove('text-ink-soft');
        tab.setAttribute('aria-selected', 'true');

        panels.forEach(function (p) {
          p.classList.add('hidden');
        });
        const activePanel = document.querySelector('[data-panel-index="' + index + '"]');
        if (activePanel) activePanel.classList.remove('hidden');
      });
    });

    /* Activate the first tab on load */
    const firstTab = tabs[0];
    if (firstTab) {
      firstTab.classList.add('bg-raised', 'text-ink');
      firstTab.classList.remove('text-ink-soft');
    }
  })();
</script>
