---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/Hero.astro';

const documents = [
  {
    title: 'Terms of Service',
    href: '/legal/terms-of-service',
    description: 'The terms governing your use of Fimil.',
  },
  {
    title: 'Privacy Policy',
    href: '/legal/privacy-policy',
    description: 'How we collect, use, and protect your data.',
  },
  {
    title: 'Security Policy',
    href: '/legal/security-policy',
    description: 'Our security practices and vulnerability reporting.',
  },
  {
    title: 'Acceptable Use Policy',
    href: '/legal/acceptable-use-policy',
    description: 'Rules for acceptable use of the platform.',
  },
  {
    title: 'Cookie Policy',
    href: '/legal/cookie-policy',
    description: 'How we use cookies and similar technologies.',
  },
  {
    title: 'Data Processing Agreement',
    href: '/legal/data-processing-agreement',
    description: 'Our commitments as a data processor.',
  },
  {
    title: 'Service Level Agreement',
    href: '/legal/service-level-agreement',
    description: 'Uptime guarantees and support commitments.',
  },
  {
    title: 'DMCA Takedown',
    href: '/legal/dmca',
    description: 'Copyright infringement notification process.',
  },
];
---

<BaseLayout
  title="Legal — Fimil"
  description="Legal documents, policies, and agreements for the Fimil platform."
>
  <Hero headline="Legal" subheadline="Our policies, terms, and agreements." />

  <section class="py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-4">
        {
          documents.map((doc) => (
            <a
              href={doc.href}
              class="scroll-hidden group rounded-xl border border-gray-200 bg-white p-5 transition-shadow hover:shadow-lg"
            >
              <h2 class="text-lg font-semibold text-gray-900 group-hover:text-fimil-600">
                {doc.title}
              </h2>
              <p class="mt-1 text-sm text-gray-600">{doc.description}</p>
            </a>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
