---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Acceptable Use Policy',
  url: 'https://fimil.dev/legal/acceptable-use-policy',
  publisher: { '@type': 'Organization', name: 'Fimil', url: 'https://fimil.dev' },
  dateModified: '2026-03-01',
};
---

<BaseLayout
  title="Acceptable Use Policy — Fimil"
  description="Rules for acceptable use of the Fimil platform."
  noindex
  jsonLd={jsonLd}
>
  <Breadcrumbs items={[{ label: 'Legal', href: '/legal' }, { label: 'Acceptable Use Policy' }]} />
  <article class="py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <a href="/legal" class="text-sm text-fimil-600 hover:text-fimil-700">&larr; Legal</a>
      <h1 class="mt-4 text-3xl font-bold text-gray-900">Acceptable Use Policy</h1>
      <p class="mt-2 text-sm text-gray-500">Effective Date: March 1, 2026</p>

      <div class="mt-10 space-y-8 text-sm leading-relaxed text-gray-600">
        <section>
          <h2 class="text-xl font-semibold text-gray-900">1. Permitted Use</h2>
          <p class="mt-2">
            Fimil is intended for scanning your own repositories and code that you have
            authorization to scan.
          </p>
        </section>

        <section>
          <h2 class="text-xl font-semibold text-gray-900">2. Prohibited Activities</h2>
          <p class="mt-2">
            You may not use the Service to scan code you do not own or have permission to scan,
            attempt to circumvent usage limits, reverse engineer the platform, or engage in any
            activity that violates applicable laws.
          </p>
        </section>

        <section>
          <h2 class="text-xl font-semibold text-gray-900">3. Enforcement</h2>
          <p class="mt-2">
            Violations may result in suspension or termination of your account. We reserve the right
            to investigate and take appropriate action.
          </p>
        </section>

        <section>
          <h2 class="text-xl font-semibold text-gray-900">4. Contact</h2>
          <p class="mt-2">
            Report AUP violations to <a href="mailto:abuse@fimil.dev" class="text-fimil-600"
              >abuse@fimil.dev</a
            >.
          </p>
        </section>
      </div>
    </div>
  </article>
</BaseLayout>
