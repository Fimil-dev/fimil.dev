---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'DMCA',
  url: 'https://fimil.dev/legal/dmca',
  publisher: { '@type': 'Organization', name: 'Fimil', url: 'https://fimil.dev' },
  dateModified: '2026-03-01',
};
---

<BaseLayout
  title="DMCA Takedown — Fimil"
  description="Copyright infringement notification process for the Fimil platform."
  jsonLd={jsonLd}
>
  <Breadcrumbs items={[{ label: 'Legal', href: '/legal' }, { label: 'DMCA' }]} />
  <article class="py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <a href="/legal" class="text-sm text-fimil-600 hover:text-fimil-700">&larr; Legal</a>
      <h1 class="mt-4 text-3xl font-bold text-gray-900">DMCA Takedown Policy</h1>
      <p class="mt-2 text-sm text-gray-500">Effective Date: March 1, 2026</p>

      <div class="mt-10 space-y-8 text-sm leading-relaxed text-gray-600">
        <section>
          <h2 class="text-xl font-semibold text-gray-900">1. Reporting Copyright Infringement</h2>
          <p class="mt-2">
            If you believe content on the Fimil platform infringes your copyright, submit a DMCA
            takedown notice to <a href="mailto:legal@fimil.dev" class="text-fimil-600"
              >legal@fimil.dev</a
            >.
          </p>
        </section>

        <section>
          <h2 class="text-xl font-semibold text-gray-900">2. Required Information</h2>
          <p class="mt-2">
            Your notice must include: identification of the copyrighted work, the infringing
            material and its location, your contact information, a good faith statement, a statement
            of accuracy under penalty of perjury, and your physical or electronic signature.
          </p>
        </section>

        <section>
          <h2 class="text-xl font-semibold text-gray-900">3. Counter-Notification</h2>
          <p class="mt-2">
            If you believe content was removed in error, you may submit a counter-notification with
            the required information under the DMCA.
          </p>
        </section>

        <section>
          <h2 class="text-xl font-semibold text-gray-900">4. Contact</h2>
          <p class="mt-2">
            DMCA Agent: <a href="mailto:legal@fimil.dev" class="text-fimil-600">legal@fimil.dev</a>
          </p>
        </section>
      </div>
    </div>
  </article>
</BaseLayout>
