---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Privacy Policy',
  url: 'https://fimil.dev/legal/privacy-policy',
  publisher: { '@type': 'Organization', name: 'Fimil', url: 'https://fimil.dev' },
  dateModified: '2026-03-01',
};
---

<BaseLayout
  title="Privacy Policy — Fimil"
  description="How Fimil collects, uses, and protects your personal data."
  noindex
  jsonLd={jsonLd}
>
  <Breadcrumbs items={[{ label: 'Legal', href: '/legal' }, { label: 'Privacy Policy' }]} />
  <article class="py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <a href="/legal" class="text-sm text-fimil-600 hover:text-fimil-700">&larr; Legal</a>
      <h1 class="mt-4 text-3xl font-bold text-gray-900">Privacy Policy</h1>
      <p class="mt-2 text-sm text-gray-500">Effective Date: March 1, 2026</p>

      <div class="mt-10 space-y-8 text-sm leading-relaxed text-gray-600">
        <section>
          <h2 class="text-xl font-semibold text-gray-900">1. Information We Collect</h2>
          <p class="mt-2">
            We collect information you provide directly (account details, contact forms) and
            information generated through your use of the Service (scan metadata, usage analytics).
          </p>
        </section>

        <section>
          <h2 class="text-xl font-semibold text-gray-900">2. How We Use Your Information</h2>
          <p class="mt-2">
            We use your information to provide and improve the Service, communicate with you, and
            ensure security and compliance.
          </p>
        </section>

        <section>
          <h2 class="text-xl font-semibold text-gray-900">3. Data Retention</h2>
          <p class="mt-2">
            We retain your data for as long as your account is active or as needed to provide the
            Service. You may request deletion at any time.
          </p>
        </section>

        <section>
          <h2 class="text-xl font-semibold text-gray-900">4. Data Sharing</h2>
          <p class="mt-2">
            We do not sell your personal data. We share data only with service providers necessary
            to operate the platform, as listed in our <a
              href="https://trust.fimil.dev"
              class="text-fimil-600"
              target="_blank"
              rel="noopener">Trust Center</a
            >.
          </p>
        </section>

        <section>
          <h2 class="text-xl font-semibold text-gray-900">5. Your Rights</h2>
          <p class="mt-2">
            Depending on your jurisdiction, you may have rights to access, correct, delete, or port
            your data. Contact <a href="mailto:privacy@fimil.dev" class="text-fimil-600"
              >privacy@fimil.dev</a
            > to exercise your rights.
          </p>
        </section>

        <section>
          <h2 class="text-xl font-semibold text-gray-900">6. Security</h2>
          <p class="mt-2">
            We implement industry-standard security measures. See our <a
              href="/legal/security-policy"
              class="text-fimil-600">Security Policy</a
            > for details.
          </p>
        </section>

        <section>
          <h2 class="text-xl font-semibold text-gray-900">7. Contact</h2>
          <p class="mt-2">
            For privacy inquiries, contact <a href="mailto:privacy@fimil.dev" class="text-fimil-600"
              >privacy@fimil.dev</a
            >.
          </p>
        </section>
      </div>
    </div>
  </article>
</BaseLayout>
