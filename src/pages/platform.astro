---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import Hero from '@/components/Hero.astro';
import Section from '@/components/Section.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import FeatureSplit from '@/components/FeatureSplit.astro';
import PipelineDiagram from '@/components/mockups/PipelineDiagram.astro';
import FindingsTableMockup from '@/components/mockups/FindingsTableMockup.astro';
import FixPrMockup from '@/components/mockups/FixPrMockup.astro';
import LogoWall from '@/components/LogoWall.astro';
import CTASection from '@/components/CTASection.astro';
import Icon from '@/components/Icon.astro';
import type { IconName } from '@/lib/icons';

const correlationTypes = [
  { name: 'same-location', description: 'Two scanners flag the same file and line.' },
  {
    name: 'code + vulnerable dep',
    description: 'Your code calls into a dependency with a known CVE.',
  },
  {
    name: 'IaC + container',
    description: 'A misconfiguration and the image it produces, linked.',
  },
  { name: 'shared CVE / CWE', description: 'The same weakness surfacing across artifacts.' },
];

const fixSurfaces = [
  {
    title: 'Dependencies',
    description:
      'Semver-aware bumps across 7+ package ecosystems, with confidence scoring on every upgrade.',
  },
  {
    title: 'Infrastructure as code',
    description:
      'Terraform, CloudFormation, and Kubernetes manifest fixes, validated after patching.',
  },
  {
    title: 'Code',
    description:
      '100+ CWE handlers across Python, JavaScript, Go, Java, C#, Ruby, and Rust — parameterized queries, output encoding, safe deserialization.',
  },
  {
    title: 'Secrets',
    description: 'Rotation and revocation guidance per secret type, opened as an actionable PR.',
  },
];

const entryPoints: { icon: IconName; title: string; description: string }[] = [
  {
    icon: 'git-branch',
    title: 'SCM integrations',
    description:
      'GitHub, GitLab, and Bitbucket: OAuth, repo sync, webhooks, PR check runs, and commit status.',
  },
  {
    icon: 'message-square',
    title: 'Notifications',
    description:
      'Slack, email, Telegram, PagerDuty, and custom webhooks with per-user preferences.',
  },
  {
    icon: 'terminal',
    title: 'CLI',
    description:
      'A pre-commit gate and CI commands: scan, wait, check — fail builds on your policy.',
  },
  {
    icon: 'bot',
    title: 'MCP server',
    description:
      'Thirteen tools covering scans, findings, triage, remediation, reports, pentest runs, and webhooks.',
  },
  {
    icon: 'workflow',
    title: 'Kubernetes operator',
    description: 'Declarative custom resources for self-hosted installs and upgrades.',
  },
  {
    icon: 'globe',
    title: 'REST API',
    description: 'Everything the dashboard does, scriptable.',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'How Fimil Works',
  url: 'https://fimil.dev/platform',
  description:
    'From git push to merged fix: scanner orchestration, cross-scanner dedup, auditable priority scoring, call-graph reachability, and fix PRs.',
};
---

<BaseLayout
  title="How Fimil Works — 16 Scanners, Dedup, Prioritization, Auto-Remediation | Fimil"
  description="From git push to merged fix: scanner orchestration, cross-scanner dedup, a 70/15/10/5 priority formula, call-graph reachability, auto-triage, and fix PRs."
  ogImage="/og-platform.png"
  jsonLd={jsonLd}
>
  <Breadcrumbs items={[{ label: 'Platform' }]} />
  <Hero
    layout="stacked"
    eyebrow="fimil platform"
    headline="From git push to merged fix."
    subheadline="What actually happens inside Fimil: one pipeline that scans, deduplicates, correlates, prioritizes, and remediates."
    primaryCta={{ label: 'Get early access', href: '/#waitlist' }}
    secondaryCta={{ label: 'See the spec sheet', href: '/features' }}
  >
    <div class="w-full"><PipelineDiagram /></div>
  </Hero>

  {/* Stage 1 — scan */}
  <Section variant="panel">
    <SectionHeading
      eyebrow="stage 01 · scan"
      title="Sixteen scanners, one orchestrator."
      lead="Each scanner runs in an isolated environment; outputs normalize into a single finding schema. SAST, SCA, containers, SBOM, secrets, IaC, DAST, CSPM — plus the AI Pentest Agent."
    />
    <LogoWall />
  </Section>

  {/* Stage 2 — dedupe */}
  <Section>
    <FeatureSplit
      eyebrow="stage 02 · deduplicate"
      title="Trivy and Grype found the same CVE. You see one finding."
      description="Fingerprints collapse identical findings across scanners; finding groups link related ones with four correlation types — so a Terraform misconfiguration and the container it produced read as one story, not two tickets."
      icon="fingerprint"
      bullets={correlationTypes.map((c) => `${c.name} — ${c.description}`)}
    >
      <FindingsTableMockup />
    </FeatureSplit>
  </Section>

  {/* Stage 3 — prioritize */}
  <Section variant="panel">
    <FeatureSplit
      eyebrow="stage 03 · prioritize"
      title="A score you can audit."
      description="The composite is published, not proprietary: 70% severity, 15% age, 10% reachability, 5% EPSS. Call-graph reachability goes beyond direct-vs-transitive — it walks your code to the vulnerable function and shows the chain, with a confidence rating."
      icon="target"
      reverse
    >
      <div class="w-full max-w-md space-y-3">
        <div class="rounded-xl border border-edge bg-panel p-4">
          <div class="flex items-center justify-between">
            <span class="font-mono text-xs text-ink-faint">priority_factors</span>
            <span class="font-mono text-xl font-bold text-fimil-400">94 / 100</span>
          </div>
          <div class="mt-3 space-y-2 font-mono text-[12px] text-ink-soft">
            <div class="flex justify-between">
              <span>severity: critical</span>
              <span class="text-critical">66.5</span>
            </div>
            <div class="flex justify-between">
              <span>age: 34 days</span>
              <span class="text-medium">12.0</span>
            </div>
            <div class="flex justify-between">
              <span>reachability: reachable</span>
              <span class="text-low">10.0</span>
            </div>
            <div class="flex justify-between">
              <span>epss: 0.91</span>
              <span class="text-fimil-400">4.6</span>
            </div>
          </div>
        </div>
        <div
          class="overflow-x-auto rounded-xl border border-edge bg-code-bg px-4 py-3 font-mono text-[11px] whitespace-nowrap text-ink-soft"
        >
          api/handler.py:42 → utils/parse.py:18 → lodash.merge()
          <span class="badge-low ml-2">confidence: high</span>
        </div>
      </div>
    </FeatureSplit>
  </Section>

  {/* Stage 4 — triage */}
  <Section>
    <FeatureSplit
      eyebrow="stage 04 · triage"
      title="Rules, not heroics."
      description="Auto-triage rules match on rule id, CVE, package, path, or title — first match wins, and every status change lands in an audit trail. Mark a test fixture as accepted-risk once; never see it again, and always be able to show why."
      icon="list-checks"
    >
      <div class="w-full max-w-md overflow-hidden rounded-xl border border-edge bg-panel">
        <div class="border-b border-edge px-4 py-3">
          <div class="flex items-center gap-2">
            <span class="font-mono text-xs font-semibold text-ink">rule: test-fixtures-fp</span>
            <span class="badge-info">priority 10</span>
          </div>
          <p class="mt-2 font-mono text-[11px] text-ink-soft">
            if file_path ~ ^tests/fixtures/ → FALSE_POSITIVE
          </p>
        </div>
        <div class="space-y-1.5 px-4 py-3 font-mono text-[11px] text-ink-faint">
          <p>
            <span class="text-ink-soft">audit:</span> finding f_8a21 OPEN → FALSE_POSITIVE
          </p>
          <p><span class="text-ink-soft">by:</span> triage-rule test-fixtures-fp</p>
          <p><span class="text-ink-soft">at:</span> 2026-06-02T14:11:09Z</p>
        </div>
      </div>
    </FeatureSplit>
  </Section>

  {/* Stage 5 — fix */}
  <Section variant="panel">
    <SectionHeading
      eyebrow="stage 05 · fix"
      title="Remediation across four surfaces."
      lead="All delivered as pull requests with diffs — review and merge, don't transcribe."
    />
    <div class="grid gap-6 sm:grid-cols-2">
      {
        fixSurfaces.map((surface) => (
          <div class="scroll-hidden rounded-2xl border border-edge bg-ground p-6">
            <h3 class="text-lg font-semibold text-ink">{surface.title}</h3>
            <p class="mt-2 text-sm leading-6 text-ink-soft">{surface.description}</p>
          </div>
        ))
      }
    </div>
    <div class="mt-10 flex justify-center">
      <FixPrMockup />
    </div>
  </Section>

  {/* Entry points */}
  <Section>
    <SectionHeading
      eyebrow="integration"
      title="Six ways in."
      lead="The pipeline meets you wherever your code already lives."
    />
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        entryPoints.map((entry) => (
          <div class="scroll-hidden rounded-2xl border border-edge bg-panel p-6 transition-colors hover:border-edge-bright hover:bg-raised">
            <Icon name={entry.icon} class="h-5 w-5 text-fimil-400" />
            <h3 class="mt-4 text-lg font-semibold text-ink">{entry.title}</h3>
            <p class="mt-2 text-sm leading-6 text-ink-soft">{entry.description}</p>
          </div>
        ))
      }
    </div>
  </Section>

  {/* Deploy */}
  <Section variant="panel" spacing="md">
    <div class="mx-auto max-w-3xl text-center">
      <SectionHeading
        eyebrow="deployment"
        title="SaaS or self-hosted."
        lead="Fimil Cloud for zero-ops, or the full platform inside your own network — including air-gapped installs — with license tiers for both."
      />
      <a
        href="/security"
        class="inline-flex items-center gap-1 text-base font-medium text-fimil-400 transition-colors hover:text-fimil-300"
      >
        How we handle your code
        <Icon name="arrow-right" class="h-4 w-4" />
      </a>
    </div>
  </Section>

  <CTASection
    headline="See the whole pipeline on your own repos."
    description="Connect a repo, run a scan, and watch 16 scanners become one signal."
    cta={{ label: 'Get early access', href: '/#waitlist' }}
  />
</BaseLayout>
