---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/Hero.astro';
---

<BaseLayout
  title="Contact — Fimil"
  description="Get in touch with the Fimil team. Questions about features, pricing, partnerships, or support."
>
  <Hero
    headline="Get in Touch"
    subheadline="Have questions about Fimil? We'd love to hear from you. Send us a message and we'll respond within 24 hours."
  />

  <section class="py-20">
    <div class="mx-auto grid max-w-5xl gap-12 px-4 sm:px-6 md:grid-cols-2 lg:px-8">
      {/* Contact form */}
      <div>
        <h2 class="text-xl font-bold tracking-tight text-gray-900">Send Us a Message</h2>
        <p class="mt-4 text-gray-600">
          Fill out the form below and we'll get back to you as soon as possible.
        </p>
        <form id="contact-form" class="mt-6 space-y-5">
          <div>
            <label for="name" class="block text-sm font-medium text-gray-700">Name</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="mt-1 block w-full rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm text-gray-900 focus:border-fimil-500 focus:ring-fimil-500"
            />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-gray-700">Email</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="mt-1 block w-full rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm text-gray-900 focus:border-fimil-500 focus:ring-fimil-500"
            />
          </div>
          <div>
            <label for="company" class="block text-sm font-medium text-gray-700">Company</label>
            <input
              type="text"
              id="company"
              name="company"
              class="mt-1 block w-full rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm text-gray-900 focus:border-fimil-500 focus:ring-fimil-500"
            />
          </div>
          <div>
            <label for="inquiry_type" class="block text-sm font-medium text-gray-700"
              >Inquiry Type</label
            >
            <select
              id="inquiry_type"
              name="inquiry_type"
              class="mt-1 block w-full rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm text-gray-900 focus:border-fimil-500 focus:ring-fimil-500"
            >
              <option value="general">General</option>
              <option value="sales">Sales</option>
              <option value="support">Support</option>
              <option value="partnership">Partnership</option>
            </select>
          </div>
          <div>
            <label for="message" class="block text-sm font-medium text-gray-700">Message</label>
            <textarea
              id="message"
              name="message"
              rows="4"
              required
              class="mt-1 block w-full rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm text-gray-900 focus:border-fimil-500 focus:ring-fimil-500"
            ></textarea>
          </div>
          <button
            type="submit"
            class="w-full rounded-lg bg-fimil-600 px-6 py-3 text-sm font-medium text-white transition-colors hover:bg-fimil-700 disabled:opacity-50"
          >
            Send Message
          </button>
          <div id="form-status" class="hidden text-sm"></div>
        </form>
      </div>

      {/* Right column */}
      <div class="space-y-8">
        {/* Book a Demo */}
        <div class="rounded-2xl bg-gray-50 p-8">
          <h3 class="text-lg font-semibold text-gray-900">Book a Demo</h3>
          <p class="mt-4 text-sm text-gray-600">
            Want to see Fimil in action? Schedule a personalized demo with our team. We'll walk you
            through:
          </p>
          <ul class="mt-4 space-y-3 text-sm text-gray-600">
            <li class="flex items-start gap-2">
              <span class="mt-0.5 h-2 w-2 flex-shrink-0 rounded-full bg-fimil-600"></span>
              How Fimil orchestrates multiple security scanners
            </li>
            <li class="flex items-start gap-2">
              <span class="mt-0.5 h-2 w-2 flex-shrink-0 rounded-full bg-fimil-600"></span>
              Our intelligent noise reduction and prioritization
            </li>
            <li class="flex items-start gap-2">
              <span class="mt-0.5 h-2 w-2 flex-shrink-0 rounded-full bg-fimil-600"></span>
              Git integrations and CI/CD pipeline setup
            </li>
            <li class="flex items-start gap-2">
              <span class="mt-0.5 h-2 w-2 flex-shrink-0 rounded-full bg-fimil-600"></span>
              Enterprise features and self-hosted deployment
            </li>
          </ul>
          <div class="mt-6">
            <a
              href="mailto:sales@fimil.dev?subject=Demo%20Request"
              class="inline-block w-full rounded-lg bg-fimil-600 px-6 py-3 text-center text-sm font-medium text-white transition-colors hover:bg-fimil-700"
            >
              Schedule a Demo
            </a>
          </div>
        </div>

        {/* Contact Information */}
        <div class="rounded-2xl border border-gray-200 bg-white p-8">
          <h3 class="text-lg font-semibold text-gray-900">Contact Information</h3>
          <div class="mt-4 space-y-3 text-sm text-gray-600">
            <p>
              <span class="font-medium text-gray-900">Sales:</span>
              <a href="mailto:sales@fimil.dev" class="ml-1 text-fimil-600">sales@fimil.dev</a>
            </p>
            <p>
              <span class="font-medium text-gray-900">Support:</span>
              <a href="mailto:support@fimil.dev" class="ml-1 text-fimil-600">support@fimil.dev</a>
            </p>
            <p>
              <span class="font-medium text-gray-900">Security:</span>
              <a href="mailto:security@fimil.dev" class="ml-1 text-fimil-600">security@fimil.dev</a>
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  document.getElementById('contact-form').addEventListener('submit', function (e) {
    e.preventDefault();
    const form = e.target;
    const btn = form.querySelector('button[type="submit"]');
    const status = document.getElementById('form-status');

    btn.disabled = true;
    btn.textContent = 'Sending...';

    const data = {
      name: form.name.value,
      email: form.email.value,
      company: form.company.value || null,
      inquiry_type: form.inquiry_type.value,
      message: form.message.value,
    };

    fetch('https://app.fimil.dev/api/v1/contact', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(data),
    })
      .then(function (res) {
        if (!res.ok) throw new Error('Request failed');
        status.textContent =
          "Message Sent! Thank you for reaching out. We'll get back to you within 24 hours.";
        status.className = 'text-sm text-green-600';
        status.classList.remove('hidden');
        form.reset();
      })
      .catch(function () {
        status.textContent = 'Something went wrong. Please email us directly.';
        status.className = 'text-sm text-red-600';
        status.classList.remove('hidden');
      })
      .finally(function () {
        btn.disabled = false;
        btn.textContent = 'Send Message';
      });
  });
</script>
