---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import FeatureCard from '@/components/FeatureCard.astro';
import CTASection from '@/components/CTASection.astro';

const scanningFeatures = [
  {
    title: 'SAST',
    description:
      'Static Application Security Testing with Semgrep, Bandit, and Gosec. Find vulnerabilities in your source code before deployment.',
  },
  {
    title: 'SCA',
    description:
      'Software Composition Analysis with Trivy, Grype, and OSV-Scanner. Identify vulnerable dependencies across all ecosystems.',
  },
  {
    title: 'Secrets Detection',
    description:
      'Find exposed API keys, passwords, and credentials with Gitleaks and TruffleHog. Prevent data breaches before they happen.',
  },
  {
    title: 'IaC Security',
    description:
      'Scan Terraform, CloudFormation, Kubernetes manifests, and Dockerfiles with Checkov and Hadolint for misconfigurations.',
  },
  {
    title: 'Container Scanning',
    description:
      'Analyze container images for vulnerabilities with Trivy. Secure your Docker images before pushing to production.',
  },
  {
    title: 'SBOM Generation',
    description:
      "Generate Software Bill of Materials with Syft. Know exactly what's in your applications for compliance and security.",
  },
];

const intelligenceFeatures = [
  {
    title: 'Priority Scoring',
    description:
      'Weighted scoring based on severity, age, reachability, and EPSS. Focus on the issues most likely to be exploited.',
  },
  {
    title: 'Reachability Analysis',
    description:
      'Distinguish between direct and transitive dependencies. Prioritize vulnerabilities in code you actually use.',
  },
  {
    title: 'EPSS Enrichment',
    description:
      'Exploit Prediction Scoring System integration. Know which CVEs are being actively exploited in the wild.',
  },
  {
    title: 'Auto-Triage',
    description:
      'Create rules to automatically classify findings as false positives, accepted risks, or confirmed vulnerabilities.',
  },
];

const workflowFeatures = [
  {
    title: 'Scanner Profiles',
    description:
      'Create reusable scanner configurations for different project types. Python, Node.js, Go, Java — optimize for your stack.',
  },
  {
    title: 'Fix Suggestions',
    description:
      'Get actionable remediation guidance. Package upgrades, code fixes, and configuration changes — all in one place.',
  },
  {
    title: 'Scan Policies',
    description:
      'Define thresholds for blocking deployments. Fail CI builds when critical findings exceed your tolerance.',
  },
  {
    title: 'Diff-Aware Scanning',
    description:
      'PR scans compare against the base branch. See only new findings, not the entire backlog.',
  },
];

const integrationFeatures = [
  {
    title: 'GitHub Integration',
    description:
      'OAuth connection, automatic repository sync, PR check runs, and commit status updates. Works with GitHub Enterprise.',
  },
  {
    title: 'GitLab Integration',
    description:
      'Connect GitLab.com or self-hosted instances. Merge request scanning with inline comments.',
  },
  {
    title: 'Bitbucket Integration',
    description: 'Bitbucket Cloud support with pull request scanning and build status updates.',
  },
  {
    title: 'Notifications',
    description:
      'Email and Slack notifications for scan results, critical findings, and weekly digests. Stay informed, not overwhelmed.',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Fimil',
  applicationCategory: 'SecurityApplication',
  operatingSystem: 'Web',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
};
---

<BaseLayout
  title="Security Scanning Features — SAST, SCA, Secrets, IaC, Container | Fimil"
  description="Comprehensive application security with Semgrep, Trivy, Gitleaks, Checkov, and more. Priority scoring, EPSS enrichment, reachability analysis, auto-triage, and CI/CD integration."
  jsonLd={jsonLd}
>
  <Breadcrumbs items={[{ label: 'Features' }]} />
  {/* Header */}
  <section class="bg-gradient-to-b from-fimil-50 to-white py-16 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <h1 class="text-4xl font-bold tracking-tight text-gray-900 sm:text-5xl">
          Everything You Need for Application Security
        </h1>
        <p class="mt-6 text-lg text-gray-600">
          One platform to orchestrate, analyze, and act on security findings across your entire
          codebase.
        </p>
      </div>
    </div>
  </section>

  {/* Comprehensive Security Scanning */}
  <section class="py-16 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12">
        <h2 class="text-2xl font-bold text-gray-900 sm:text-3xl">
          Comprehensive Security Scanning
        </h2>
        <p class="mt-2 text-lg text-gray-600">
          Industry-leading open source tools, unified under one roof.
        </p>
      </div>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {scanningFeatures.map((f) => <FeatureCard title={f.title} description={f.description} />)}
      </div>
    </div>
  </section>

  {/* Intelligent Prioritization */}
  <section class="bg-gray-50 py-16 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12">
        <h2 class="text-2xl font-bold text-gray-900 sm:text-3xl">Intelligent Prioritization</h2>
        <p class="mt-2 text-lg text-gray-600">Cut through the noise. Focus on what matters.</p>
      </div>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {
          intelligenceFeatures.map((f) => (
            <FeatureCard title={f.title} description={f.description} />
          ))
        }
      </div>
    </div>
  </section>

  {/* Developer Workflow */}
  <section class="py-16 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12">
        <h2 class="text-2xl font-bold text-gray-900 sm:text-3xl">Developer Workflow</h2>
        <p class="mt-2 text-lg text-gray-600">Security that fits into how you already work.</p>
      </div>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {workflowFeatures.map((f) => <FeatureCard title={f.title} description={f.description} />)}
      </div>
    </div>
  </section>

  {/* Integrations */}
  <section class="bg-gray-50 py-16 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12">
        <h2 class="text-2xl font-bold text-gray-900 sm:text-3xl">Integrations</h2>
        <p class="mt-2 text-lg text-gray-600">Connect your tools. Automate your security.</p>
      </div>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {
          integrationFeatures.map((f) => (
            <FeatureCard title={f.title} description={f.description} />
          ))
        }
      </div>
    </div>
  </section>

  {/* CTA */}
  <CTASection
    headline="See Fimil in Action"
    description="Join the waitlist to start scanning your repositories. No credit card required."
    cta={{ label: 'Join Waitlist', href: '/#waitlist' }}
  />
</BaseLayout>
