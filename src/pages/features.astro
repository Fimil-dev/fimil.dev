---
import BaseLayout from '@/layouts/BaseLayout.astro';
import FeatureCard from '@/components/FeatureCard.astro';
import CTASection from '@/components/CTASection.astro';

const scanningFeatures = [
  {
    title: 'Static Application Security Testing',
    description: 'Find vulnerabilities in your source code with Semgrep, Bandit, and Gosec.',
    label: 'SAST',
  },
  {
    title: 'Software Composition Analysis',
    description: 'Identify vulnerable dependencies with Trivy, Grype, and OSV-Scanner.',
    label: 'SCA',
  },
  {
    title: 'Secrets Detection',
    description: 'Find leaked API keys, tokens, and credentials with Gitleaks and TruffleHog.',
    label: 'Secrets',
  },
  {
    title: 'Infrastructure as Code Security',
    description:
      'Infrastructure as Code scanning with Checkov — catch misconfigurations before deployment.',
    label: 'IaC',
  },
  {
    title: 'Container Scanning',
    description: 'Scan Docker images for OS and application vulnerabilities with Trivy.',
    label: 'Containers',
  },
  {
    title: 'SBOM Generation',
    description:
      'Generate Software Bill of Materials with Syft for compliance and supply chain security.',
    label: 'SBOM',
  },
];

const prioritizationFeatures = [
  {
    title: 'Priority Scoring',
    description:
      'Weighted scoring based on severity, EPSS, reachability, and finding age. Focus on what matters.',
  },
  {
    title: 'Reachability Analysis',
    description: 'Know if a vulnerable dependency is actually called in your code paths.',
  },
  {
    title: 'EPSS Enrichment',
    description: 'Real-world exploit probability scores from FIRST.org. Not just CVSS severity.',
  },
  {
    title: 'Auto-Triage',
    description: 'Pattern-matching rules to automatically classify findings. Reduce noise by 90%.',
  },
];

const workflowFeatures = [
  {
    title: 'Scanner Profiles',
    description: 'Reusable scanner configurations. Apply the right tools to the right projects.',
  },
  {
    title: 'Fix Suggestions',
    description:
      'Auto-generated remediation guidance — version bumps, config changes, code patches.',
  },
  {
    title: 'Scan Policies',
    description: 'Define quality gates and enforcement rules per repository or organization.',
  },
  {
    title: 'Diff-Aware Scanning',
    description: 'PR scans show only new findings. No noise from pre-existing issues.',
  },
];

const integrationFeatures = [
  {
    title: 'GitHub',
    description: 'Native GitHub App integration — status checks, PR comments, repository sync.',
  },
  {
    title: 'GitLab',
    description: 'Full GitLab integration with merge request scanning and commit status.',
  },
  {
    title: 'Bitbucket',
    description: 'Bitbucket Cloud integration with pull request scanning and status updates.',
  },
  {
    title: 'Notifications',
    description: 'Slack, email, and webhook notifications for scan results and critical findings.',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Fimil',
  applicationCategory: 'SecurityApplication',
  featureList: [
    ...scanningFeatures.map((f) => f.label),
    ...prioritizationFeatures.map((f) => f.title),
    ...workflowFeatures.map((f) => f.title),
    ...integrationFeatures.map((f) => f.title),
  ].join(', '),
};
---

<BaseLayout
  title="Features — Fimil"
  description="Everything you need for application security. SAST, SCA, secrets detection, IaC scanning, container scanning, and SBOM generation — all behind a single dashboard."
  jsonLd={jsonLd}
>
  {/* Header */}
  <section
    class="relative overflow-hidden bg-gradient-to-b from-fimil-50 to-white py-20 sm:py-28 dark:from-gray-900 dark:to-gray-950"
  >
    <div
      class="absolute top-0 -left-40 h-80 w-80 rounded-full bg-fimil-200/30 blur-3xl dark:bg-fimil-800/20"
      aria-hidden="true"
    >
    </div>
    <div
      class="absolute -right-40 bottom-0 h-80 w-80 rounded-full bg-fimil-200/30 blur-3xl dark:bg-fimil-800/20"
      aria-hidden="true"
    >
    </div>
    <div class="relative mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
      <h1
        class="font-heading text-4xl font-bold tracking-tight text-gray-900 sm:text-5xl lg:text-6xl dark:text-white"
      >
        Everything You Need for Application Security
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-gray-600 sm:text-xl dark:text-gray-400">
        Fimil orchestrates best-in-class open-source scanners and unifies their output into a
        single, actionable view.
      </p>
      <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a
          href="https://app.fimil.dev/auth/register"
          class="rounded-lg bg-fimil-600 px-6 py-3 text-base font-medium text-white shadow-sm transition-colors hover:bg-fimil-700"
        >
          Get Started Free
        </a>
      </div>
    </div>
  </section>

  {/* Comprehensive Security Scanning */}
  <section class="py-20 dark:bg-gray-950">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2
        class="text-center font-heading text-2xl font-bold tracking-tight text-gray-900 sm:text-3xl dark:text-white"
      >
        Comprehensive Security Scanning
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-center text-gray-600 dark:text-gray-400">
        12+ open-source scanners covering every layer of your application stack.
      </p>
      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {scanningFeatures.map((f) => <FeatureCard title={f.title} description={f.description} />)}
      </div>
    </div>
  </section>

  {/* Intelligent Prioritization */}
  <section
    class="border-t border-gray-200/60 bg-gray-50 py-20 dark:border-gray-800/60 dark:bg-gray-900"
  >
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2
        class="text-center font-heading text-2xl font-bold tracking-tight text-gray-900 sm:text-3xl dark:text-white"
      >
        Intelligent Prioritization
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-center text-gray-600 dark:text-gray-400">
        Cut through the noise. Focus on the vulnerabilities that actually matter.
      </p>
      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-2">
        {
          prioritizationFeatures.map((f) => (
            <FeatureCard title={f.title} description={f.description} />
          ))
        }
      </div>
    </div>
  </section>

  {/* Developer Workflow */}
  <section class="py-20 dark:bg-gray-950">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2
        class="text-center font-heading text-2xl font-bold tracking-tight text-gray-900 sm:text-3xl dark:text-white"
      >
        Developer Workflow
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-center text-gray-600 dark:text-gray-400">
        Security that fits into how your team already works.
      </p>
      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-2">
        {workflowFeatures.map((f) => <FeatureCard title={f.title} description={f.description} />)}
      </div>
    </div>
  </section>

  {/* Integrations */}
  <section
    class="border-t border-gray-200/60 bg-gray-50 py-20 dark:border-gray-800/60 dark:bg-gray-900"
  >
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2
        class="text-center font-heading text-2xl font-bold tracking-tight text-gray-900 sm:text-3xl dark:text-white"
      >
        Integrations
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-center text-gray-600 dark:text-gray-400">
        Connect your repositories and tools from any major platform.
      </p>
      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-2">
        {
          integrationFeatures.map((f) => (
            <FeatureCard title={f.title} description={f.description} />
          ))
        }
      </div>
    </div>
  </section>

  {/* CTA */}
  <CTASection
    headline="Start Scanning in 5 Minutes"
    description="Connect your repos, run your first scan, and see unified results — all in the free tier."
    cta={{ label: 'Get Started Free', href: 'https://app.fimil.dev/auth/register' }}
  />
</BaseLayout>
