---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import FeatureCard from '@/components/FeatureCard.astro';
import Section from '@/components/Section.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import CTASection from '@/components/CTASection.astro';
import Button from '@/components/Button.astro';
import Icon from '@/components/Icon.astro';
import type { IconName } from '@/lib/icons';

type Feature = { title: string; description: string; icon?: IconName };

const scanningFeatures: Feature[] = [
  {
    title: 'SAST',
    icon: 'file-code',
    description:
      'Static analysis with Semgrep, Bandit, and Gosec. Find injection, crypto, and logic flaws in source before deployment.',
  },
  {
    title: 'SCA',
    icon: 'package',
    description:
      'Dependency scanning with Trivy, Grype, and OSV-Scanner across every major ecosystem — deduplicated into one finding per CVE.',
  },
  {
    title: 'Secrets detection',
    icon: 'key',
    description:
      'Gitleaks and TruffleHog find exposed API keys, passwords, and tokens — with rotation guidance per secret type.',
  },
  {
    title: 'IaC security',
    icon: 'sliders',
    description:
      'Checkov and Hadolint scan Terraform, CloudFormation, Kubernetes manifests, and Dockerfiles for misconfigurations.',
  },
  {
    title: 'Container scanning',
    icon: 'container',
    description:
      'Trivy analyzes images layer by layer — base image CVEs, stale packages, bad configs.',
  },
  {
    title: 'DAST',
    icon: 'globe',
    description:
      'OWASP ZAP and Nuclei probe your running app from outside: missing headers, exposed panels, known-template vulnerabilities.',
  },
  {
    title: 'CSPM',
    icon: 'cloud',
    description:
      'Prowler audits AWS, Azure, and GCP accounts for cloud misconfigurations — correlated with the IaC that caused them.',
  },
  {
    title: 'SBOM generation',
    icon: 'list-checks',
    description:
      'Syft generates CycloneDX and SPDX software bills of materials per scan, stored and exportable for compliance.',
  },
];

const intelligenceFeatures: Feature[] = [
  {
    title: 'Cross-scanner dedup',
    description:
      'Fingerprints collapse the same issue found by multiple scanners into one finding with every source credited.',
  },
  {
    title: 'Finding groups',
    description:
      'Four correlation types link related findings: same-location, code + vulnerable dep, IaC + container, shared CVE/CWE.',
  },
  {
    title: 'Priority scoring',
    description:
      'An auditable composite: 70% severity, 15% age, 10% reachability, 5% EPSS — published weights, no black box.',
  },
  {
    title: 'Call-graph reachability',
    description:
      'Walks your code to the vulnerable function and shows the call chain with a confidence rating — beyond direct vs. transitive.',
  },
  {
    title: 'EPSS enrichment',
    description:
      'Exploit Prediction Scoring System data on every CVE — know what is being exploited in the wild.',
  },
  {
    title: 'Auto-triage rules',
    description:
      'Match on rule id, CVE, package, path, or title; first match wins; every transition lands in an audit trail.',
  },
];

const remediationFeatures: Feature[] = [
  {
    title: 'Dependency fix PRs',
    description: 'Semver-aware bumps across 7+ ecosystems with upgrade-confidence scoring.',
  },
  {
    title: 'IaC fix PRs',
    description: 'Terraform, CloudFormation, and Kubernetes fixes, validated after patching.',
  },
  {
    title: 'Code fix PRs',
    description: '75+ CWE-specific handlers across Python, JS, Go, Java, C#, Ruby, Rust, and PHP.',
  },
  {
    title: 'Pentest advisory PRs',
    description:
      'Confirmed agent findings open a PR with the PoC, curl repro, and remediation guidance.',
  },
];

const workflowFeatures: Feature[] = [
  {
    title: 'PR checks',
    description:
      'GitHub check runs, GitLab and Bitbucket commit status — block merges on your policy.',
  },
  {
    title: 'Diff-aware scanning',
    description: 'PR scans compare against the base branch: only new findings, not the backlog.',
  },
  {
    title: 'Scan policies',
    description: 'Severity thresholds that fail CI builds when findings exceed your tolerance.',
  },
  {
    title: 'Scanner profiles',
    description:
      'Reusable configurations per stack — Python, Node, Go, Java — tuned once, used everywhere.',
  },
  {
    title: 'CLI',
    description: 'Pre-commit gate and CI commands with retry-safe API access.',
  },
  {
    title: 'MCP server',
    description:
      'More than 40 tools for AI assistants: scans, findings, triage, remediation, reports, pentest.',
  },
  {
    title: 'Kubernetes operator',
    description: 'Declarative installs for self-hosted clusters via custom resources.',
  },
  {
    title: 'Notifications',
    description: 'Slack, email, and custom webhooks with per-user preferences.',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Fimil',
  applicationCategory: 'SecurityApplication',
  operatingSystem: 'Web',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
  featureList: [
    'SAST',
    'SCA',
    'Secrets detection',
    'IaC security',
    'Container scanning',
    'DAST',
    'CSPM',
    'SBOM generation',
    'AI pentest agent',
    'Cross-scanner deduplication',
    'Priority scoring',
    'Call-graph reachability',
    'Auto-triage rules',
    'Auto-remediation PRs',
  ].join(', '),
};
---

<BaseLayout
  title="Security Features — SAST, SCA, DAST, CSPM, Secrets, IaC, SBOM | Fimil"
  description="The full capability reference: 15 open-source scanners across 8 categories, an AI pentest agent, the intelligence layer, the remediation engine, and every integration."
  jsonLd={jsonLd}
>
  <Breadcrumbs items={[{ label: 'Features' }]} />
  {/* Header */}
  <section class="relative overflow-hidden py-16 sm:py-24">
    <div class="bg-grid absolute inset-0" aria-hidden="true"></div>
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <p class="font-mono text-sm tracking-widest text-fimil-400 uppercase">spec sheet</p>
        <h1 class="mt-4 text-4xl font-bold tracking-tight text-ink sm:text-5xl">
          Everything Fimil does, on one page.
        </h1>
        <p class="mt-6 text-lg text-ink-soft">
          The dense version. For the story, read <a
            href="/platform"
            class="text-fimil-400 transition-colors hover:text-fimil-300">how the pipeline works</a
          > or meet <a href="/pentest" class="text-fimil-400 transition-colors hover:text-fimil-300"
            >the pentest agent</a
          >.
        </p>
      </div>
    </div>
  </section>

  {/* Scanning */}
  <Section>
    <SectionHeading
      align="left"
      eyebrow="scanning"
      title="Eight scanning categories"
      lead="Fifteen open-source scanners, isolated runs, one normalized output schema."
    />
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        scanningFeatures.map((f) => (
          <FeatureCard title={f.title} description={f.description} icon={f.icon} />
        ))
      }
    </div>
  </Section>

  {/* AI Pentest summary */}
  <Section variant="panel" spacing="md">
    <div
      class="flex flex-col items-start gap-6 rounded-2xl border border-fimil-400/30 bg-ground p-8 lg:flex-row lg:items-center"
    >
      <div class="flex-1">
        <p class="font-mono text-sm tracking-widest text-fimil-400 uppercase">flagship</p>
        <h2 class="mt-2 text-2xl font-bold text-ink">AI Pentest Agent</h2>
        <ul class="mt-4 space-y-2">
          <li class="flex items-start gap-2.5 text-sm text-ink-soft">
            <Icon name="check" class="mt-0.5 h-4 w-4 shrink-0 text-low" />
            15 attack vectors, from SQLi and IDOR to SSTI and JWT attacks
          </li>
          <li class="flex items-start gap-2.5 text-sm text-ink-soft">
            <Icon name="check" class="mt-0.5 h-4 w-4 shrink-0 text-low" />
            Every finding replay-validated before it is reported
          </li>
          <li class="flex items-start gap-2.5 text-sm text-ink-soft">
            <Icon name="check" class="mt-0.5 h-4 w-4 shrink-0 text-low" />
            PoC + curl reproduction export, compliance mappings, advisory fix PRs
          </li>
        </ul>
      </div>
      <Button href="/pentest" size="lg">Meet the agent</Button>
    </div>
  </Section>

  {/* Intelligence */}
  <Section>
    <SectionHeading align="left" eyebrow="intelligence" title="One signal, not sixteen feeds" />
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {intelligenceFeatures.map((f) => <FeatureCard title={f.title} description={f.description} />)}
    </div>
  </Section>

  {/* Remediation */}
  <Section variant="panel">
    <SectionHeading align="left" eyebrow="remediation" title="Fixes as pull requests" />
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {remediationFeatures.map((f) => <FeatureCard title={f.title} description={f.description} />)}
    </div>
  </Section>

  {/* Workflow & integrations */}
  <Section>
    <SectionHeading align="left" eyebrow="workflow" title="Workflow & integrations" />
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {workflowFeatures.map((f) => <FeatureCard title={f.title} description={f.description} />)}
    </div>
  </Section>

  {/* Deployment */}
  <Section variant="panel" spacing="md">
    <div class="mx-auto max-w-3xl text-center">
      <SectionHeading
        eyebrow="deployment"
        title="Fimil Cloud or self-hosted"
        lead="Multi-tenant SaaS with usage-based pentest billing, or licensed single-tenant in your own network — including air-gapped installs."
      />
    </div>
  </Section>

  <CTASection
    headline="See it against your own repos."
    description="Get early access and run your first scan. No credit card required."
    cta={{ label: 'Get early access', href: '/#waitlist' }}
  />
</BaseLayout>
