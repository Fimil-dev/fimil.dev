---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/Hero.astro';
import FeatureCard from '@/components/FeatureCard.astro';
import CTASection from '@/components/CTASection.astro';

const scanners = [
  { category: 'SAST', tools: ['Semgrep', 'Bandit', 'Gosec'], icon: '\u{1F50D}' },
  { category: 'SCA', tools: ['Trivy', 'Grype', 'OSV-Scanner'], icon: '\u{1F4E6}' },
  { category: 'Secrets', tools: ['Gitleaks', 'TruffleHog'], icon: '\u{1F511}' },
  { category: 'IaC', tools: ['Checkov', 'Hadolint'], icon: '\u{1F3D7}\u{FE0F}' },
  { category: 'Containers', tools: ['Trivy Image'], icon: '\u{1F4E5}' },
  { category: 'SBOM', tools: ['Syft'], icon: '\u{1F4CB}' },
];

const platformFeatures = [
  {
    icon: '\u{1F3AF}',
    title: 'EPSS Priority Scoring',
    description: 'Findings ranked by real-world exploit probability, not just CVSS severity.',
  },
  {
    icon: '\u{1F916}',
    title: 'AI Triage Assistant',
    description: 'Automated triage suggestions based on context, reachability, and exposure.',
  },
  {
    icon: '\u{1F501}',
    title: 'Cross-Tool Deduplication',
    description: 'Multiple scanners, zero duplicate findings. Smart correlation across tools.',
  },
  {
    icon: '\u{1F527}',
    title: 'Auto-Remediation',
    description: 'One-click fixes and auto-generated PRs to resolve vulnerabilities fast.',
  },
  {
    icon: '\u{1F4CA}',
    title: 'Reachability Analysis',
    description: 'Know which vulnerabilities are actually reachable in your code paths.',
  },
  {
    icon: '\u{2699}\u{FE0F}',
    title: 'Scan Policies',
    description: 'Custom scanner profiles, auto-triage rules, and configurable scan schedules.',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Fimil',
  applicationCategory: 'SecurityApplication',
  featureList: platformFeatures.map((f) => f.title).join(', '),
};
---

<BaseLayout
  title="Features — Fimil"
  description="12+ open-source security scanners orchestrated behind a single dashboard. SAST, SCA, secrets, IaC, containers, and SBOM."
  jsonLd={jsonLd}
>
  <Hero
    headline="All Your Security Scanners, One Dashboard"
    subheadline="Fimil orchestrates best-in-class open-source scanners and unifies their output into a single, actionable view."
    primaryCta={{ label: 'Get Started Free', href: 'https://app.fimil.dev/auth/register' }}
  />

  {/* Scanner grid */}
  <section class="py-20 dark:bg-gray-950">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2
        class="text-center font-heading text-2xl font-bold tracking-tight text-gray-900 dark:text-white"
      >
        Integrated Scanners
      </h2>
      <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          scanners.map((s) => (
            <div class="reveal rounded-xl border border-gray-200 bg-white p-6 dark:border-gray-800 dark:bg-gray-900">
              <div class="flex items-center gap-3">
                <span class="text-2xl">{s.icon}</span>
                <h3 class="font-heading text-lg font-semibold text-gray-900 dark:text-white">
                  {s.category}
                </h3>
              </div>
              <div class="mt-3 flex flex-wrap gap-2">
                {s.tools.map((tool) => (
                  <span class="rounded-full bg-fimil-50 px-3 py-1 text-xs font-medium text-fimil-700 dark:bg-fimil-900/50 dark:text-fimil-300">
                    {tool}
                  </span>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  {/* Platform features */}
  <section
    class="border-t border-gray-200/60 bg-gray-50 py-20 dark:border-gray-800/60 dark:bg-gray-900"
  >
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2
        class="text-center font-heading text-2xl font-bold tracking-tight text-gray-900 dark:text-white"
      >
        Platform Features
      </h2>
      <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          platformFeatures.map((f) => (
            <FeatureCard title={f.title} description={f.description} icon={f.icon} />
          ))
        }
      </div>
    </div>
  </section>

  {/* Integrations */}
  <section class="py-20 dark:bg-gray-950">
    <div class="mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
      <h2 class="font-heading text-2xl font-bold tracking-tight text-gray-900 dark:text-white">
        Integrations
      </h2>
      <p class="mt-4 text-gray-600 dark:text-gray-400">
        Connect your repositories from any major Git provider.
      </p>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-8">
        {
          ['GitHub', 'GitLab', 'Bitbucket'].map((provider) => (
            <div class="reveal rounded-lg border border-gray-200 bg-white px-6 py-4 text-lg font-medium text-gray-700 dark:border-gray-800 dark:bg-gray-900 dark:text-gray-300">
              {provider}
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <CTASection
    headline="Start Scanning in 5 Minutes"
    description="Connect your repos, run your first scan, and see unified results — all in the free tier."
    cta={{ label: 'Get Started Free', href: 'https://app.fimil.dev/auth/register' }}
  />
</BaseLayout>
