---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/Hero.astro';
import DashboardMockup from '@/components/DashboardMockup.astro';
import TrustBadge from '@/components/TrustBadge.astro';
import FeatureSection from '@/components/FeatureSection.astro';
import PricingCard from '@/components/PricingCard.astro';
import WaitlistForm from '@/components/WaitlistForm.astro';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Fimil',
  url: 'https://fimil.dev',
  logo: 'https://fimil.dev/logo.svg',
  description:
    'Unified application security platform. Orchestrate 12+ open-source scanners behind a single dashboard.',
};

const stats = [
  { value: '12+', label: 'Security Scanners' },
  { value: '90%', label: 'Noise Reduction vs. Running Tools Separately' },
  { value: '5 min', label: 'To First Scan' },
  { value: '24/7', label: 'Automated Scanning' },
];

const trustTools = [
  { icon: '\u{1F50D}', name: 'Semgrep', description: 'SAST' },
  { icon: '\u{1F4E6}', name: 'Trivy', description: 'SCA & Container' },
  { icon: '\u{1F511}', name: 'Gitleaks', description: 'Secrets' },
  { icon: '\u{2705}', name: 'Checkov', description: 'IaC' },
  { icon: '\u{1F40D}', name: 'Bandit', description: 'Python Security' },
  { icon: '\u{1F433}', name: 'Hadolint', description: 'Dockerfile' },
];

const featureSections = [
  {
    title: 'Unified Dashboard',
    description:
      'Stop context-switching between a dozen security tools. Fimil unifies all your security scanners into a single, actionable view. Know exactly what to fix and where.',
    iconRight: true,
    bgGray: false,
    iconEmoji: '\u{1F4CA}',
  },
  {
    title: 'Auto-Remediation (One-Click Fixes)',
    description:
      'Most tools find bugs \u2014 Fimil fixes them. Get automatic dependency bumps, IaC configuration fixes, and AI-generated patches delivered as ready-to-merge pull requests.',
    iconRight: false,
    bgGray: true,
    iconEmoji: '\u{1F527}',
  },
  {
    title: 'EPSS-Enhanced Prioritization',
    description:
      'Not just severity \u2014 Fimil uses exploit prediction scores, reachability analysis, and finding age to surface the issues that actually matter. Fix the 3 critical issues first, ignore the rest.',
    iconRight: true,
    bgGray: false,
    iconEmoji: '\u{1F3AF}',
  },
  {
    title: 'AI Triage Assistant',
    description:
      'Plain-language explanations of CVEs, automatic triage suggestions, and executive-ready summaries. Makes security accessible to everyone on the team \u2014 not just security engineers.',
    iconRight: false,
    bgGray: true,
    iconEmoji: '\u{1F916}',
  },
];

const pricingPlans = [
  {
    name: 'Free',
    price: '$0',
    description: 'For individual developers',
    features: ['3 repos', '10 scans/month', 'All scanner types'],
    cta: { label: 'Join Waitlist', href: '/#waitlist' },
    highlighted: false,
  },
  {
    name: 'Team',
    price: '$49',
    description: 'For growing teams',
    features: ['10 repos', '100 scans/month', 'Slack & API access'],
    cta: { label: 'Join Waitlist', href: '/#waitlist' },
    highlighted: true,
  },
  {
    name: 'Business',
    price: '$199',
    description: 'For larger organizations',
    features: ['50 repos', 'Auto-triage rules', 'Priority support'],
    cta: { label: 'Contact Sales', href: '/contact' },
    highlighted: false,
  },
];
---

<BaseLayout title="Fimil \u2014 Unified Application Security Platform" jsonLd={jsonLd}>
  {/* 1. Hero with DashboardMockup */}
  <Hero
    headline="12 Security Scanners. One Dashboard. Zero Noise."
    subheadline="Fimil orchestrates best-in-class open-source security tools into a single view \u2014 so your team fixes what matters and ignores the rest."
    primaryCta={{ label: 'Join Waitlist', href: '/#waitlist' }}
    secondaryCta={{ label: 'See Features', href: '/features' }}
  >
    <DashboardMockup />
  </Hero>

  {/* 2. Stats section */}
  <section class="bg-fimil-50 py-16 dark:bg-gray-900">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-2xl text-center">
        <h2
          class="font-heading text-2xl font-bold tracking-tight text-gray-900 sm:text-3xl dark:text-white"
        >
          Built for Modern Development Teams
        </h2>
        <p class="mt-3 text-base text-gray-600 dark:text-gray-400">
          Everything you need to secure your applications at scale.
        </p>
      </div>
      <div class="mt-10 grid grid-cols-2 gap-8 md:grid-cols-4">
        {
          stats.map((stat) => (
            <div class="reveal text-center">
              <div class="font-heading text-3xl font-bold text-fimil-600 dark:text-fimil-400">
                {stat.value}
              </div>
              <div class="mt-1 text-sm text-gray-600 dark:text-gray-400">{stat.label}</div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  {/* 3. Trust Badges */}
  <section class="bg-gray-50 py-16 dark:bg-gray-900/50">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2
        class="text-center font-heading text-lg font-semibold tracking-tight text-gray-500 dark:text-gray-400"
      >
        Powered by best-in-class open source tools
      </h2>
      <div class="mt-10 grid grid-cols-2 gap-8 sm:grid-cols-3 md:grid-cols-6">
        {
          trustTools.map((tool) => (
            <TrustBadge name={tool.name} description={tool.description} icon={tool.icon} />
          ))
        }
      </div>
    </div>
  </section>

  {/* 4. Social proof */}
  <section class="py-16 dark:bg-gray-950">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <p class="text-sm font-semibold tracking-widest text-fimil-600 uppercase dark:text-fimil-400">
        Currently in Private Beta
      </p>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-gray-600 dark:text-gray-400">
        Powered by open-source tools trusted by millions of developers &mdash; Semgrep, Trivy,
        Gitleaks, Checkov, and more.
      </p>
    </div>
  </section>

  {/* 5. Alternating feature sections */}
  {
    featureSections.map((section) => (
      <FeatureSection
        title={section.title}
        description={section.description}
        iconRight={section.iconRight}
        bgGray={section.bgGray}
        iconEmoji={section.iconEmoji}
      />
    ))
  }

  {/* 6. Explore All Features link */}
  <div class="py-10 text-center dark:bg-gray-950">
    <a
      href="/features"
      class="inline-flex items-center gap-1 text-base font-medium text-fimil-600 transition-colors hover:text-fimil-700 dark:text-fimil-400 dark:hover:text-fimil-300"
    >
      Explore All Features &rarr;
    </a>
  </div>

  {/* 7. Pricing Preview */}
  <section class="bg-gray-50 py-16 sm:py-20 dark:bg-gray-900">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-2xl text-center">
        <h2
          class="font-heading text-2xl font-bold tracking-tight text-gray-900 sm:text-3xl dark:text-white"
        >
          Simple, Transparent Pricing
        </h2>
        <p class="mt-3 text-base text-gray-600 dark:text-gray-400">
          Join the waitlist. Upgrade as you grow.
        </p>
      </div>
      <div class="mt-12 grid gap-8 md:grid-cols-3">
        {
          pricingPlans.map((plan) => (
            <PricingCard
              name={plan.name}
              price={plan.price}
              description={plan.description}
              features={plan.features}
              cta={plan.cta}
              highlighted={plan.highlighted}
            />
          ))
        }
      </div>
      <div class="mt-10 text-center">
        <a
          href="/pricing"
          class="inline-flex items-center gap-1 text-base font-medium text-fimil-600 transition-colors hover:text-fimil-700 dark:text-fimil-400 dark:hover:text-fimil-300"
        >
          See All Plans & Features &rarr;
        </a>
      </div>
    </div>
  </section>

  {/* 8. Waitlist form */}
  <WaitlistForm />
</BaseLayout>
