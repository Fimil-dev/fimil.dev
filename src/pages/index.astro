---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/Hero.astro';
import TerminalDemo from '@/components/TerminalDemo.astro';
import Section from '@/components/Section.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import StatBlock from '@/components/StatBlock.astro';
import FeatureSplit from '@/components/FeatureSplit.astro';
import FindingsTableMockup from '@/components/mockups/FindingsTableMockup.astro';
import PentestAgentMockup from '@/components/mockups/PentestAgentMockup.astro';
import FixPrMockup from '@/components/mockups/FixPrMockup.astro';
import LogoWall from '@/components/LogoWall.astro';
import PricingCard from '@/components/PricingCard.astro';
import WaitlistForm from '@/components/WaitlistForm.astro';
import Icon from '@/components/Icon.astro';
import type { IconName } from '@/lib/icons';
import type { TerminalLine } from '@/components/TerminalDemo.astro';

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'Fimil',
    url: 'https://fimil.dev',
    logo: 'https://fimil.dev/logo-icon-color.svg',
    description:
      'Application security platform that finds, proves, and fixes: an autonomous pentest agent plus 16 integrated scanners, with confirmed findings delivered as proof and pull requests.',
    sameAs: ['https://github.com/Fimil-dev'],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'Fimil',
    url: 'https://fimil.dev',
  },
];

const terminalLines: TerminalLine[] = [
  { type: 'cmd', text: 'fimil scan ./api' },
  { type: 'ok', text: 'semgrep        14 findings', delay: 500 },
  { type: 'ok', text: 'trivy          31 findings' },
  { type: 'ok', text: 'gitleaks        2 findings' },
  { type: 'out', text: '+ 13 more scanners' },
  { type: 'ok', text: 'deduplicated   47 raw → 9 findings', delay: 500 },
  { type: 'crit', text: 'SQLi api/users.py:84 — exploit replayed 2/2', delay: 600 },
  { type: 'ok', text: 'fix PR #482 opened', delay: 500 },
];

const stats = [
  { value: '16', label: 'Integrated scanners', href: '/features' },
  { value: '15', label: 'Pentest attack vectors', href: '/pentest' },
  { value: '100+', label: 'CWE auto-fix handlers', href: '/platform' },
  { value: '13', label: 'MCP tools for AI assistants', href: '/platform' },
];

const workflow: { icon: IconName; title: string; description: string }[] = [
  {
    icon: 'git-branch',
    title: 'GitHub, GitLab & Bitbucket',
    description: 'OAuth connect, webhooks, PR checks, and commit status on every push.',
  },
  {
    icon: 'message-square',
    title: 'Notifications',
    description: 'Slack, email, Telegram, PagerDuty, and custom webhooks.',
  },
  {
    icon: 'terminal',
    title: 'CLI',
    description: 'Pre-commit gate and CI integration for shift-left scanning.',
  },
  {
    icon: 'bot',
    title: 'MCP server',
    description: 'Thirteen tools so your AI assistant can run scans, triage, and remediation.',
  },
  {
    icon: 'workflow',
    title: 'Kubernetes operator',
    description: 'Declarative installs and upgrades for self-hosted clusters.',
  },
  {
    icon: 'server',
    title: 'SaaS or self-hosted',
    description: 'Fimil Cloud, or run the whole platform inside your own network.',
  },
];

const priorityFactors = [
  { label: 'severity', weight: 70, color: 'bg-critical' },
  { label: 'age', weight: 15, color: 'bg-medium' },
  { label: 'reachability', weight: 10, color: 'bg-low' },
  { label: 'EPSS', weight: 5, color: 'bg-fimil-400' },
];

const pricingPlans = [
  {
    name: 'Free',
    price: 0 as const,
    description: 'For individual developers',
    features: ['3 repositories', '10 scans/month', 'All scanner types'],
    cta: { label: 'Get early access', href: '/#waitlist' },
    highlighted: false,
  },
  {
    name: 'Team',
    price: 49 as const,
    description: 'For growing teams',
    features: ['10 repositories', '100 scans/month', 'Slack, API access & SBOM export'],
    cta: { label: 'Get early access', href: '/#waitlist' },
    highlighted: true,
  },
  {
    name: 'Business',
    price: 199 as const,
    description: 'For larger organizations',
    features: [
      '50 repositories',
      '500 scans/month',
      'Auto-triage & auto-fix PRs',
      'Priority support',
    ],
    cta: { label: 'Contact Sales', href: '/contact' },
    highlighted: false,
  },
];
---

<BaseLayout title="Fimil — Finds. Proves. Fixes." jsonLd={jsonLd}>
  {/* 1. Hero with terminal demo */}
  <Hero
    layout="split"
    headline="Finds it. Proves it. Fixes it."
    subheadline="Fimil pentests your running app with an autonomous agent, validates every finding by replaying the exploit, and opens the fix PR — on top of 16 integrated scanners covering code, dependencies, containers, IaC, secrets, and cloud."
    primaryCta={{ label: 'Get early access', href: '/#waitlist' }}
    secondaryCta={{ label: 'See the pentest agent', href: '/pentest' }}
  >
    <TerminalDemo lines={terminalLines} title="~/acme/api" />
  </Hero>

  {/* 2. Mechanics stat strip */}
  <Section variant="panel" spacing="md">
    <SectionHeading
      eyebrow="what's inside"
      title="No adjectives. Just the numbers."
      lead="Every number links to the page that proves it."
    />
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {stats.map((stat) => <StatBlock value={stat.value} label={stat.label} href={stat.href} />)}
    </div>
  </Section>

  {/* 3. FINDS */}
  <Section>
    <FeatureSplit
      eyebrow="finds"
      title="One scan, every layer."
      description="Sixteen scanners across SAST, SCA, containers, secrets, IaC, DAST, CSPM, and SBOM run as one pipeline. Cross-scanner fingerprinting collapses the same CVE found by Trivy and Grype into a single finding — with every source credited."
      icon="layers"
      link={{ label: 'How the pipeline works', href: '/platform' }}
    >
      <FindingsTableMockup />
    </FeatureSplit>
  </Section>

  {/* 4. PROVES */}
  <Section variant="panel">
    <FeatureSplit
      eyebrow="proves"
      title="No finding ships without a working exploit."
      description="The pentest agent doesn't pattern-match — it attacks across 15 vectors, and a validator replays every candidate exploit before it reaches your dashboard. Each confirmed finding exports a PoC and a copy-paste curl reproduction."
      icon="shield-check"
      reverse
      link={{ label: 'Meet the pentest agent', href: '/pentest' }}
    >
      <PentestAgentMockup />
    </FeatureSplit>
  </Section>

  {/* 5. FIXES */}
  <Section>
    <FeatureSplit
      eyebrow="fixes"
      title="The finding is the pull request."
      description="Semver-aware dependency bumps across 7+ ecosystems, Terraform/CloudFormation/Kubernetes fixes, code fixes from 100+ CWE handlers, and advisory fix PRs opened from confirmed pentest findings — each one a ready-to-merge diff."
      icon="git-pull-request"
      link={{ label: 'See the remediation engine', href: '/platform' }}
    >
      <FixPrMockup />
    </FeatureSplit>
  </Section>

  {/* 6. One signal — priority score breakdown */}
  <Section variant="panel">
    <FeatureSplit
      eyebrow="one signal"
      title="A priority score you can audit."
      description="Not a black box: 70% severity, 15% age, 10% reachability, 5% EPSS. Call-graph reachability looks past direct-vs-transitive to whether the vulnerable function is actually called — and shows you the call chain."
      icon="target"
      reverse
    >
      <div class="w-full max-w-md rounded-xl border border-edge bg-panel p-5">
        <div class="flex items-center justify-between">
          <span class="text-sm font-semibold text-ink">Priority score</span>
          <span class="font-mono text-2xl font-bold text-fimil-400">94</span>
        </div>
        <div class="mt-3 flex h-2.5 w-full gap-0.5 overflow-hidden rounded-full">
          {
            priorityFactors.map((f) => (
              <span class:list={[f.color, 'h-full']} style={`width: ${f.weight}%`} />
            ))
          }
        </div>
        <div class="mt-3 flex flex-wrap gap-x-4 gap-y-1">
          {
            priorityFactors.map((f) => (
              <span class="flex items-center gap-1.5 font-mono text-[11px] text-ink-soft">
                <span class:list={[f.color, 'h-2 w-2 rounded-full']} />
                {f.label} {f.weight}%
              </span>
            ))
          }
        </div>
        <div
          class="mt-4 overflow-x-auto rounded-md border border-edge bg-code-bg px-3 py-2 font-mono text-[11px] whitespace-nowrap text-ink-soft"
        >
          handler.py:42 → utils/parse.py:18 → lodash.merge() <span class="badge-low ml-1"
            >reachable</span
          >
        </div>
      </div>
    </FeatureSplit>
  </Section>

  {/* 7. Workflow grid */}
  <Section>
    <SectionHeading
      eyebrow="workflow"
      title="Meet your code where it lives."
      lead="Six ways into the platform — none of them require changing how you ship."
    />
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        workflow.map((item) => (
          <div class="scroll-hidden rounded-2xl border border-edge bg-panel p-6 transition-colors hover:border-edge-bright hover:bg-raised">
            <Icon name={item.icon} class="h-5 w-5 text-fimil-400" />
            <h3 class="mt-4 text-lg font-semibold text-ink">{item.title}</h3>
            <p class="mt-2 text-sm leading-6 text-ink-soft">{item.description}</p>
          </div>
        ))
      }
    </div>
  </Section>

  {/* 8. Scanner wall */}
  <Section variant="panel">
    <SectionHeading
      eyebrow="built on open source"
      title="Sixteen scanners. One orchestrator."
      lead="Fimil orchestrates best-in-class open-source scanners — and adds the layers they can't: validation, correlation, and remediation."
    />
    <LogoWall />
  </Section>

  {/* 9. Pricing teaser */}
  <Section>
    <SectionHeading
      eyebrow="pricing"
      title="Start free. Pay for what you scan."
      lead="AI Pentest is usage-based on paid plans — you pay per confirmed finding, and false positives are credited."
    />
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {
        pricingPlans.map((plan) => (
          <PricingCard
            name={plan.name}
            price={plan.price}
            description={plan.description}
            features={plan.features}
            cta={plan.cta}
            highlighted={plan.highlighted}
          />
        ))
      }
    </div>
    <div class="mt-8 text-center">
      <a
        href="/pricing"
        data-astro-prefetch="load"
        class="inline-flex items-center gap-1 text-base font-medium text-fimil-400 transition-colors hover:text-fimil-300"
      >
        Compare all plans &amp; the AI Pentest add-on
        <Icon name="arrow-right" class="h-4 w-4" />
      </a>
    </div>
  </Section>

  {/* 10. Waitlist */}
  <WaitlistForm />
</BaseLayout>
