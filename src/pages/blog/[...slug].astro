---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

const wordCount = post.body?.split(/\s+/).length ?? 0;
const readingTime = Math.max(1, Math.round(wordCount / 200));

const tocHeadings = headings.filter((h) => h.depth === 2);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.date.toISOString(),
  author: {
    '@type': 'Person',
    name: post.data.author,
  },
};
---

<BaseLayout
  title={`${post.data.title} — Fimil Blog`}
  description={post.data.description}
  ogImage={post.data.ogImage}
  jsonLd={jsonLd}
>
  <Breadcrumbs items={[{ label: 'Blog', href: '/blog' }, { label: post.data.title }]} />
  <article class="py-12 sm:py-16 lg:py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:max-w-4xl lg:px-8">
      <header class="mb-10 border-b border-gray-200 pb-10">
        <a href="/blog" class="text-sm text-fimil-600 transition-colors hover:text-fimil-700">
          &larr; Back to Blog
        </a>
        <div class="mt-4 flex items-center gap-3 text-sm text-gray-500">
          <time datetime={post.data.date.toISOString()}>
            {
              post.data.date.toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'long',
                day: 'numeric',
              })
            }
          </time>
          <span aria-hidden="true">&middot;</span>
          <span>{readingTime} min read</span>
        </div>
        <h1 class="mt-3 text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">
          {post.data.title}
        </h1>
        <p class="mt-2 text-sm text-gray-500">By {post.data.author}</p>
        {
          post.data.tags.length > 0 && (
            <div class="mt-4 flex flex-wrap gap-2">
              {post.data.tags.map((tag) => (
                <span class="rounded-full bg-fimil-50 px-2.5 py-0.5 text-xs font-medium text-fimil-700">
                  {tag}
                </span>
              ))}
            </div>
          )
        }
      </header>

      {
        tocHeadings.length > 2 && (
          <nav class="mb-10 rounded-xl border border-gray-200 bg-gray-50 p-6">
            <p class="text-sm font-semibold tracking-wider text-gray-500 uppercase">
              In this article
            </p>
            <ol class="mt-3 space-y-2">
              {tocHeadings.map((heading) => (
                <li>
                  <a
                    href={`#${heading.slug}`}
                    class="text-sm text-gray-600 transition-colors hover:text-fimil-600"
                  >
                    {heading.text}
                  </a>
                </li>
              ))}
            </ol>
          </nav>
        )
      }

      <div
        class="prose prose-gray prose-a:text-fimil-600 prose-first:text-lg prose-first:text-gray-500 prose-first:leading-relaxed max-w-none"
      >
        <Content />
      </div>

      <footer class="mt-16 border-t border-gray-200 pt-8">
        <a
          href="/blog"
          class="inline-flex items-center gap-1 text-sm font-medium text-fimil-600 transition-colors hover:text-fimil-700"
        >
          &larr; More from the Fimil Blog
        </a>
      </footer>
    </div>
  </article>
</BaseLayout>
