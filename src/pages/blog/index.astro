---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import Hero from '@/components/Hero.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Fimil Blog',
  url: 'https://fimil.dev/blog',
  description:
    'Application security insights, product updates, and engineering deep-dives from the Fimil team.',
  publisher: { '@type': 'Organization', name: 'Fimil', url: 'https://fimil.dev' },
  ...(posts.length > 0 && {
    mainEntity: {
      '@type': 'ItemList',
      itemListElement: posts.map((post, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        url: `https://fimil.dev/blog/${post.id}`,
        name: post.data.title,
      })),
    },
  }),
};
---

<BaseLayout
  title="Blog — Fimil"
  description="Application security insights, product updates, and engineering deep-dives from the Fimil team."
  jsonLd={jsonLd}
>
  <Breadcrumbs items={[{ label: 'Blog' }]} />
  <Hero
    headline="Blog"
    subheadline="Application security insights, product updates, and engineering deep-dives."
  />

  <section class="py-12 sm:py-16 lg:py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:max-w-4xl lg:px-8">
      {
        posts.length > 0 ? (
          <div class="space-y-8">
            {posts.map((post) => (
              <article class="scroll-hidden rounded-xl border border-gray-200 bg-white p-6 transition-shadow hover:shadow-lg">
                <a href={`/blog/${post.id}`}>
                  <time datetime={post.data.date.toISOString()} class="text-sm text-gray-500">
                    {post.data.date.toLocaleDateString('en-US', {
                      year: 'numeric',
                      month: 'long',
                      day: 'numeric',
                    })}
                  </time>
                  <h2 class="mt-2 text-xl font-semibold text-gray-900">{post.data.title}</h2>
                  <p class="mt-2 text-sm text-gray-600">{post.data.description}</p>
                  {post.data.tags.length > 0 && (
                    <div class="mt-3 flex flex-wrap gap-2">
                      {post.data.tags.map((tag) => (
                        <span class="rounded-full bg-fimil-50 px-2.5 py-0.5 text-xs font-medium text-fimil-700">
                          {tag}
                        </span>
                      ))}
                    </div>
                  )}
                </a>
              </article>
            ))}
          </div>
        ) : (
          <div class="text-center text-gray-500">
            <p class="text-lg">No posts yet. Check back soon.</p>
          </div>
        )
      }
    </div>
  </section>
</BaseLayout>
