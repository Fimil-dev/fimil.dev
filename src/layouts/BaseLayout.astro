---
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';

interface Props {
  title: string;
  description?: string | undefined;
  ogImage?: string | undefined;
  canonicalPath?: string | undefined;
  noindex?: boolean | undefined;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[] | undefined;
}

const {
  title,
  description = 'Application security that finds, proves, and fixes. An autonomous pentest agent plus 16 integrated scanners, with every confirmed finding delivered as proof and a pull request.',
  ogImage = '/og-default.png',
  canonicalPath,
  noindex = false,
  jsonLd,
} = Astro.props;

const canonicalUrl = new URL(canonicalPath ?? Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a0e14" />
    <meta name="color-scheme" content="dark" />
    <meta
      name="robots"
      content={noindex
        ? 'noindex, follow'
        : 'index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1'}
    />
    <meta name="generator" content={Astro.generator} />

    <script is:inline>
      document.documentElement.classList.add('js');
    </script>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/logo-icon-color.png" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" type="application/rss+xml" title="Fimil Blog" href="/rss.xml" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Fimil Changelog"
      href="/changelog.xml"
    />

    {/* Open Graph */}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Fimil" />
    <meta property="og:locale" content="en_US" />

    {/* Twitter */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />

    {/* Font preloads */}
    <link
      rel="preload"
      href="/fonts/ibm-plex-sans-400.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/ibm-plex-mono-400.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    {/* JSON-LD */}
    {
      jsonLd && (
        <script
          type="application/ld+json"
          set:html={JSON.stringify(Array.isArray(jsonLd) ? jsonLd : [jsonLd])}
        />
      )
    }
  </head>
  <body class="min-h-screen bg-ground text-ink">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />

    {/* Scroll reveal observer */}
    <script is:inline>
      const observer = new IntersectionObserver(
        function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add('scroll-visible');
            }
          });
        },
        { threshold: 0.1 },
      );
      document.querySelectorAll('.scroll-hidden').forEach(function (el) {
        observer.observe(el);
      });
    </script>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
