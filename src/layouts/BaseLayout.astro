---
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';

interface Props {
  title: string;
  description?: string | undefined;
  ogImage?: string | undefined;
  canonicalPath?: string | undefined;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[] | undefined;
}

const {
  title,
  description = 'Unified application security platform. Orchestrate 12+ open-source scanners behind a single dashboard.',
  ogImage = '/og-default.png',
  canonicalPath,
  jsonLd,
} = Astro.props;

const canonicalUrl = new URL(canonicalPath ?? Astro.url.pathname, Astro.site);
const fontsUrl =
  'https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600;700&family=IBM+Plex+Sans:wght@400;500;600&display=swap';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0284c7" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalUrl} />

    {/* Open Graph */}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <meta property="og:site_name" content="Fimil" />

    {/* Twitter */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />

    {/* Fonts */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href={fontsUrl} />

    {/* JSON-LD */}
    {
      jsonLd && (
        <script
          type="application/ld+json"
          set:html={JSON.stringify(Array.isArray(jsonLd) ? jsonLd : [jsonLd])}
        />
      )
    }
  </head>
  <body class="min-h-screen bg-white text-gray-900">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />

    {/* Scroll reveal observer */}
    <script is:inline>
      const observer = new IntersectionObserver(
        function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add('scroll-visible');
            }
          });
        },
        { threshold: 0.1 },
      );
      document.querySelectorAll('.scroll-hidden').forEach(function (el) {
        observer.observe(el);
      });
    </script>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
