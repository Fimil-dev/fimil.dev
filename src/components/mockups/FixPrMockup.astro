---
// GitHub-style pull request card with a real-looking diff hunk.
import Icon from '@/components/Icon.astro';
import DiffBlock from '@/components/DiffBlock.astro';
---

<div class="max-w-lg overflow-hidden rounded-xl border border-edge bg-panel">
  <div class="border-b border-edge px-4 py-3">
    <div class="flex items-center gap-2">
      <Icon name="git-pull-request" class="h-4 w-4 shrink-0 text-low" />
      <span class="badge-low">Open</span>
      <span class="truncate text-[13px] font-semibold text-ink">
        fix(deps): bump lodash 4.17.20 → 4.17.21
      </span>
    </div>
    <div class="mt-2 flex flex-wrap items-center gap-1.5 font-mono text-[11px] text-ink-faint">
      <span class="rounded bg-raised px-1.5 py-0.5">fimil/fix-CVE-2021-23337</span>
      <span>→</span>
      <span class="rounded bg-raised px-1.5 py-0.5">main</span>
    </div>
  </div>

  <div class="border-b border-edge">
    <div
      class="flex items-center gap-2 border-b border-edge px-4 py-1.5 font-mono text-[11px] text-ink-faint"
    >
      <Icon name="file-code" class="h-3.5 w-3.5" />
      package.json
    </div>
    <DiffBlock
      lines={[
        { type: 'ctx', text: '  "dependencies": {' },
        { type: 'ctx', text: '    "express": "^4.21.2",' },
        { type: 'del', text: '    "lodash": "4.17.20",' },
        { type: 'add', text: '    "lodash": "4.17.21",' },
        { type: 'ctx', text: '    "pino": "^9.6.0"' },
        { type: 'ctx', text: '  }' },
      ]}
    />
  </div>

  <div class="flex flex-wrap items-center gap-x-4 gap-y-1 px-4 py-3 text-[12px] text-ink-soft">
    <span class="flex items-center gap-1.5">
      <span class="flex h-5 w-5 items-center justify-center rounded-full bg-fimil-400/15">
        <Icon name="bot" class="h-3 w-3 text-fimil-400" />
      </span>
      <span class="font-mono">fimil-bot</span>
    </span>
    <span class="flex items-center gap-1">
      <Icon name="check" class="h-3.5 w-3.5 text-low" />
      All checks passed
    </span>
    <span class="font-mono text-ink-faint">Closes #482</span>
  </div>
</div>
