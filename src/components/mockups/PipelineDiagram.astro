---
// The platform pipeline: scan → normalize → dedupe → prioritize → fix.
// CSS grid + real text (selectable, accessible) — only the chevrons are SVG.
import Icon from '@/components/Icon.astro';

const scannerNames = [
  'semgrep',
  'trivy',
  'grype',
  'gitleaks',
  'checkov',
  'zap',
  'nuclei',
  'prowler',
];

const stages = [
  { title: 'Scan', detail: '16 scanners, isolated runs' },
  { title: 'Normalize', detail: 'one finding schema' },
  { title: 'Deduplicate', detail: 'fingerprints + groups' },
  { title: 'Prioritize', detail: 'severity · age · reach · EPSS' },
  { title: 'Fix', detail: 'ready-to-merge PRs' },
];
---

<ol
  aria-label="Fimil pipeline"
  class="flex flex-col items-stretch gap-2 lg:flex-row lg:items-center"
>
  {
    stages.map((stage, i) => (
      <>
        <li class="flex-1 rounded-xl border border-edge bg-panel p-4">
          <div class="flex items-baseline gap-2">
            <span class="font-mono text-xs text-ink-faint">0{i + 1}</span>
            <span class="text-sm font-semibold text-ink">{stage.title}</span>
          </div>
          <p class="mt-1 font-mono text-[11px] text-ink-soft">{stage.detail}</p>
          {i === 0 && (
            <div class="mt-2 grid grid-cols-4 gap-1">
              {scannerNames.map((name) => (
                <span class="truncate rounded border border-edge bg-raised px-1 py-0.5 text-center font-mono text-[9px] text-ink-faint">
                  {name}
                </span>
              ))}
            </div>
          )}
          {i === 2 && <p class="mt-2 font-mono text-lg font-bold text-fimil-400">4,213 → 387</p>}
          {i === 3 && (
            <div class="mt-2 flex flex-wrap gap-1">
              <span class="badge-critical">epss 0.91</span>
              <span class="badge-low">reachable</span>
            </div>
          )}
          {i === 4 && (
            <div class="mt-2 flex items-center gap-1.5 font-mono text-[11px] text-low">
              <Icon name="git-pull-request" class="h-3.5 w-3.5" />
              PR #482 opened
            </div>
          )}
        </li>
        {i < stages.length - 1 && (
          <li aria-hidden="true" class="flex justify-center text-ink-faint">
            <Icon name="arrow-right" class="h-4 w-4 rotate-90 lg:rotate-0" />
          </li>
        )}
      </>
    ))
  }
</ol>
