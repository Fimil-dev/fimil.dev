---
// Waitlist sign-up form — POSTs to Fimil-Cloud API.
// Uses is:inline script for submission handling.
---

<section id="waitlist" class="bg-fimil-600 py-16 sm:py-20 dark:bg-fimil-800">
  <div class="mx-auto max-w-2xl px-4 text-center sm:px-6 lg:px-8">
    <h2 class="font-heading text-2xl font-bold text-white sm:text-3xl">Get Early Access</h2>
    <p class="mx-auto mt-4 max-w-lg text-fimil-100">
      Be the first to know when Fimil launches. Join the waitlist today.
    </p>

    <form
      id="waitlist-form"
      class="mx-auto mt-8 max-w-md space-y-4"
      action="https://app.fimil.dev/api/v1/waitlist"
      method="POST"
    >
      <div>
        <label for="waitlist-email" class="sr-only">Email address</label>
        <input
          id="waitlist-email"
          name="email"
          type="email"
          required
          placeholder="you@company.com"
          class="w-full rounded-lg border border-fimil-400 bg-white/10 px-4 py-3 text-sm text-white placeholder-fimil-200 backdrop-blur-sm transition focus:border-white focus:ring-2 focus:ring-white/30 focus:outline-none"
        />
      </div>
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
        <div>
          <label for="waitlist-name" class="sr-only">Name</label>
          <input
            id="waitlist-name"
            name="name"
            type="text"
            placeholder="Your name"
            class="w-full rounded-lg border border-fimil-400 bg-white/10 px-4 py-3 text-sm text-white placeholder-fimil-200 backdrop-blur-sm transition focus:border-white focus:ring-2 focus:ring-white/30 focus:outline-none"
          />
        </div>
        <div>
          <label for="waitlist-company" class="sr-only">Company</label>
          <input
            id="waitlist-company"
            name="company"
            type="text"
            placeholder="Company"
            class="w-full rounded-lg border border-fimil-400 bg-white/10 px-4 py-3 text-sm text-white placeholder-fimil-200 backdrop-blur-sm transition focus:border-white focus:ring-2 focus:ring-white/30 focus:outline-none"
          />
        </div>
      </div>
      <button
        type="submit"
        class="w-full rounded-lg bg-white px-6 py-3 text-sm font-semibold text-fimil-700 shadow-sm transition-colors hover:bg-fimil-50"
      >
        Join Waitlist
      </button>
      <p id="waitlist-status" class="hidden text-sm text-fimil-100"></p>
    </form>
  </div>
</section>

<script is:inline>
  (function () {
    const form = document.getElementById('waitlist-form');
    const status = document.getElementById('waitlist-status');

    form.addEventListener('submit', function (e) {
      e.preventDefault();
      const data = new FormData(form);
      const body = {};
      data.forEach(function (value, key) {
        if (value) body[key] = value;
      });

      const btn = form.querySelector('button[type="submit"]');
      btn.disabled = true;
      btn.textContent = 'Submitting...';

      fetch(form.action, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      })
        .then(function (res) {
          if (res.ok) {
            status.textContent = "You're on the list! We'll be in touch soon.";
            status.className = 'text-sm text-green-200';
            form.reset();
          } else {
            throw new Error('Request failed');
          }
        })
        .catch(function () {
          status.textContent = 'Something went wrong. Please try again.';
          status.className = 'text-sm text-red-200';
        })
        .finally(function () {
          btn.disabled = false;
          btn.textContent = 'Join Waitlist';
        });
    });
  })();
</script>
