---
// Waitlist sign-up form — POSTs to Fimil-Cloud API.
// Uses is:inline script for submission handling.
---

<section id="waitlist" class="relative overflow-hidden border-y border-edge bg-panel">
  <div
    class="pointer-events-none absolute inset-0"
    style="background: radial-gradient(60% 120% at 50% 0%, color-mix(in oklab, var(--color-fimil-500) 12%, transparent), transparent);"
    aria-hidden="true"
  >
  </div>
  <div class="relative mx-auto max-w-7xl px-4 py-16 sm:px-6 sm:py-24 lg:px-8">
    <div class="mx-auto max-w-md text-center">
      <h2 class="text-3xl font-bold tracking-tight text-ink sm:text-4xl">Get Early Access</h2>
      <p class="mt-4 text-lg text-ink-soft">
        Fimil is onboarding teams in waves. Join the list and run your first scan against your own
        repos.
      </p>

      <form
        id="waitlist-form"
        class="mt-8 space-y-4"
        action="https://app.fimil.dev/api/v1/waitlist"
        method="POST"
      >
        {/* Honeypot: hidden from real users, ignored by screen readers; bots tend to fill it. */}
        <div aria-hidden="true" class="absolute left-[-9999px] h-0 w-0 overflow-hidden">
          <label for="waitlist-website">Leave this field empty</label>
          <input
            id="waitlist-website"
            name="website"
            type="text"
            tabindex="-1"
            autocomplete="off"
          />
        </div>
        <div>
          <label for="waitlist-email" class="sr-only">Email address</label>
          <input
            id="waitlist-email"
            name="email"
            type="email"
            required
            placeholder="you@company.com"
            class="w-full rounded-lg border border-edge-bright bg-ground px-4 py-3 text-sm text-ink transition placeholder:text-ink-faint focus:border-fimil-400 focus:outline-none"
          />
        </div>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
          <div>
            <label for="waitlist-name" class="text-sm font-medium text-ink-soft">Name</label>
            <input
              id="waitlist-name"
              name="name"
              type="text"
              placeholder="Your name"
              class="mt-1 w-full rounded-lg border border-edge-bright bg-ground px-4 py-3 text-sm text-ink transition placeholder:text-ink-faint focus:border-fimil-400 focus:outline-none"
            />
          </div>
          <div>
            <label for="waitlist-company" class="text-sm font-medium text-ink-soft">Company</label>
            <input
              id="waitlist-company"
              name="company"
              type="text"
              placeholder="Company"
              class="mt-1 w-full rounded-lg border border-edge-bright bg-ground px-4 py-3 text-sm text-ink transition placeholder:text-ink-faint focus:border-fimil-400 focus:outline-none"
            />
          </div>
        </div>
        <button
          type="submit"
          class="w-full rounded-lg bg-fimil-400 px-6 py-3 text-sm font-semibold text-[#0a0e14] transition-colors hover:bg-fimil-300"
        >
          Get early access
        </button>
        <p id="waitlist-status" role="status" class="hidden text-sm text-ink-soft"></p>
      </form>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    const form = document.getElementById('waitlist-form');
    const status = document.getElementById('waitlist-status');

    // Client-side spam friction: hidden honeypot + minimum time-to-submit. Bots that
    // auto-fill every field or POST instantly are silently no-op'd. Real backend
    // rate-limiting is the server's job; this is only the client-side friction layer.
    const MIN_SUBMIT_MS = 2000;
    const renderedAt = Date.now();

    form.addEventListener('submit', function (e) {
      e.preventDefault();
      const data = new FormData(form);

      // Silently no-op if the honeypot is filled or the form was submitted
      // impossibly fast for a human. Fake "success" so bots get no signal.
      if (data.get('website') || Date.now() - renderedAt < MIN_SUBMIT_MS) {
        status.textContent = "You're on the list! We'll be in touch soon.";
        status.className = 'text-sm text-low';
        form.reset();
        return;
      }

      const body = {};
      data.forEach(function (value, key) {
        if (key !== 'website' && value) body[key] = value;
      });

      const btn = form.querySelector('button[type="submit"]');
      btn.disabled = true;
      btn.textContent = 'Submitting...';

      fetch(form.action, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      })
        .then(function (res) {
          if (res.ok) {
            status.textContent = "You're on the list! We'll be in touch soon.";
            status.className = 'text-sm text-low';
            form.reset();
          } else {
            throw new Error('Request failed');
          }
        })
        .catch(function () {
          status.textContent = 'Something went wrong. Please try again.';
          status.className = 'text-sm text-critical';
        })
        .finally(function () {
          btn.disabled = false;
          btn.textContent = 'Get early access';
        });
    });
  })();
</script>
