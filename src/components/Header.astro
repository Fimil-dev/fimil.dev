---
import ThemeToggle from './ThemeToggle.astro';

const navLinks = [
  { label: 'Features', href: '/features' },
  { label: 'Compare', href: '/compare' },
  { label: 'Pricing', href: '/pricing' },
  { label: 'About', href: '/about' },
  { label: 'Contact', href: '/contact' },
  { label: 'Blog', href: '/blog' },
];

const currentPath = Astro.url.pathname;
---

<header
  class="sticky top-0 z-50 border-b border-gray-200/60 bg-white/80 backdrop-blur-lg dark:border-gray-800/60 dark:bg-gray-950/80"
>
  <nav class="mx-auto flex max-w-7xl items-center justify-between px-4 py-3 sm:px-6 lg:px-8">
    {/* Logo */}
    <a href="/" class="flex items-center">
      <img src="/logo-full-light.svg" alt="Fimil" class="h-8 dark:hidden" />
      <img src="/logo-full-dark.svg" alt="Fimil" class="hidden h-8 dark:block" />
    </a>

    {/* Desktop nav */}
    <div class="hidden items-center gap-1 md:flex">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              'rounded-lg px-3 py-2 text-sm font-medium transition-colors',
              currentPath.startsWith(link.href)
                ? 'text-fimil-600 dark:text-fimil-400'
                : 'text-gray-600 hover:text-gray-900 dark:text-gray-400 dark:hover:text-gray-100',
            ]}
          >
            {link.label}
          </a>
        ))
      }
    </div>

    {/* Desktop CTAs + theme toggle */}
    <div class="hidden items-center gap-3 md:flex">
      <ThemeToggle />
      <a
        href="https://app.fimil.dev/auth/login"
        class="text-sm font-medium text-gray-600 transition-colors hover:text-gray-900 dark:text-gray-400 dark:hover:text-gray-100"
      >
        Sign In
      </a>
      <a
        href="/#waitlist"
        class="rounded-lg bg-fimil-600 px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-fimil-700"
      >
        Join Waitlist
      </a>
    </div>

    {/* Mobile hamburger */}
    <div class="flex items-center gap-2 md:hidden">
      <ThemeToggle />
      <button
        id="mobile-menu-btn"
        type="button"
        class="rounded-lg p-2 text-gray-600 hover:text-gray-900 dark:text-gray-400 dark:hover:text-gray-100"
        aria-label="Open menu"
        aria-expanded="false"
      >
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path
            id="menu-icon-open"
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M4 6h16M4 12h16M4 18h16"></path>
          <path
            id="menu-icon-close"
            class="hidden"
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>
  </nav>

  {/* Mobile menu */}
  <div
    id="mobile-menu"
    class="hidden border-t border-gray-200/60 bg-white md:hidden dark:border-gray-800/60 dark:bg-gray-950"
  >
    <div class="space-y-1 px-4 py-4">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              'block rounded-lg px-3 py-2 text-base font-medium transition-colors',
              currentPath.startsWith(link.href)
                ? 'text-fimil-600 dark:text-fimil-400'
                : 'text-gray-600 hover:text-gray-900 dark:text-gray-400 dark:hover:text-gray-100',
            ]}
          >
            {link.label}
          </a>
        ))
      }
      <div
        class="mt-4 flex flex-col gap-2 border-t border-gray-200/60 pt-4 dark:border-gray-800/60"
      >
        <a
          href="https://app.fimil.dev/auth/login"
          class="rounded-lg px-3 py-2 text-center text-base font-medium text-gray-600 transition-colors hover:text-gray-900 dark:text-gray-400 dark:hover:text-gray-100"
        >
          Sign In
        </a>
        <a
          href="/#waitlist"
          class="rounded-lg bg-fimil-600 px-3 py-2 text-center text-base font-medium text-white transition-colors hover:bg-fimil-700"
        >
          Join Waitlist
        </a>
      </div>
    </div>
  </div>
</header>

<script is:inline>
  (function () {
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    const iconOpen = document.getElementById('menu-icon-open');
    const iconClose = document.getElementById('menu-icon-close');
    let isOpen = false;

    btn.addEventListener('click', function () {
      isOpen = !isOpen;
      menu.classList.toggle('hidden', !isOpen);
      iconOpen.classList.toggle('hidden', isOpen);
      iconClose.classList.toggle('hidden', !isOpen);
      btn.setAttribute('aria-expanded', String(isOpen));
      document.body.style.overflow = isOpen ? 'hidden' : '';
    });

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && isOpen) {
        btn.click();
      }
    });
  })();
</script>
