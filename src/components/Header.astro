---
const navLinks = [
  { label: 'Platform', href: '/platform' },
  { label: 'Pentest', href: '/pentest' },
  { label: 'Pricing', href: '/pricing' },
  { label: 'Changelog', href: '/changelog' },
  { label: 'Blog', href: '/blog' },
  { label: 'Contact', href: '/contact' },
];
---

<header class="sticky top-0 z-50 border-b border-edge bg-ground/80 backdrop-blur-lg">
  <nav class="mx-auto flex h-20 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">
    {/* Logo */}
    <a href="/" class="flex items-center gap-2">
      <img src="/logo-icon-color.svg" alt="" class="h-10 w-10" />
      <span class="font-mono text-2xl font-semibold tracking-wide text-ink">fimil</span>
    </a>

    {/* Desktop nav */}
    <div class="hidden items-center gap-8 md:flex">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="text-base font-medium text-ink-soft transition-colors hover:text-ink"
          >
            {link.label}
          </a>
        ))
      }
    </div>

    {/* Desktop CTAs */}
    <div class="hidden items-center gap-3 md:flex">
      <a
        href="https://app.fimil.dev/auth/login"
        class="text-base font-medium text-ink-soft transition-colors hover:text-ink"
      >
        Sign In
      </a>
      <a
        href="/#waitlist"
        class="rounded-lg bg-fimil-400 px-4 py-2 text-sm font-medium text-[#0a0e14] transition-colors hover:bg-fimil-300"
      >
        Get early access
      </a>
    </div>

    {/* Mobile hamburger */}
    <div class="flex items-center gap-2 md:hidden">
      <button
        id="mobile-menu-btn"
        type="button"
        class="rounded-lg p-2 text-ink-soft hover:text-ink"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path
            id="menu-icon-open"
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M4 6h16M4 12h16M4 18h16"></path>
          <path
            id="menu-icon-close"
            class="hidden"
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>
  </nav>

  {/* Mobile menu */}
  <div id="mobile-menu" class="hidden border-t border-edge bg-overlay md:hidden">
    <div class="space-y-1 px-4 py-4">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="block rounded-lg px-3 py-2 text-base font-medium text-ink-soft hover:bg-raised hover:text-ink"
          >
            {link.label}
          </a>
        ))
      }
      <div class="mt-4 flex flex-col gap-2 border-t border-edge pt-4">
        <a
          href="https://app.fimil.dev/auth/login"
          class="rounded-lg px-3 py-2 text-center text-base font-medium text-ink-soft transition-colors hover:text-ink"
        >
          Sign In
        </a>
        <a
          href="/#waitlist"
          class="rounded-lg bg-fimil-400 px-3 py-2 text-center text-base font-medium text-[#0a0e14] transition-colors hover:bg-fimil-300"
        >
          Get early access
        </a>
      </div>
    </div>
  </div>
</header>

{
  /* Mobile backdrop — must live OUTSIDE <header>: backdrop-blur on the header
    makes it the containing block for fixed descendants, which would paint
    this overlay on top of the open menu and swallow every tap */
}
<div id="mobile-backdrop" class="fixed inset-0 z-40 hidden bg-black/50 md:hidden"></div>

<script is:inline>
  (function () {
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    const backdrop = document.getElementById('mobile-backdrop');
    const iconOpen = document.getElementById('menu-icon-open');
    const iconClose = document.getElementById('menu-icon-close');
    let isOpen = false;

    function toggle() {
      isOpen = !isOpen;
      menu.classList.toggle('hidden', !isOpen);
      backdrop.classList.toggle('hidden', !isOpen);
      iconOpen.classList.toggle('hidden', isOpen);
      iconClose.classList.toggle('hidden', !isOpen);
      btn.setAttribute('aria-expanded', String(isOpen));
      document.body.style.overflow = isOpen ? 'hidden' : '';
    }

    btn.addEventListener('click', toggle);

    backdrop.addEventListener('click', function () {
      if (isOpen) toggle();
    });

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && isOpen) {
        toggle();
      }
    });
  })();
</script>
