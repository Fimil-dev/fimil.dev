---
// Animated terminal window. SSR renders the final state (the no-JS, SEO, and
// reduced-motion output); an inline script replays it on scroll-into-view.
// Lines are hidden with visibility (never display) so replay causes zero CLS.
export interface TerminalLine {
  type: 'cmd' | 'out' | 'ok' | 'warn' | 'crit';
  text: string;
  delay?: number;
}

interface Props {
  lines: TerminalLine[];
  title?: string | undefined;
  animate?: boolean | undefined;
  class?: string | undefined;
}

const { lines, title = '~/api-service', animate = true, class: className } = Astro.props;

const glyphs: Record<TerminalLine['type'], string> = {
  cmd: '$',
  out: '',
  ok: '✓',
  warn: '!',
  crit: '✗',
};

const glyphClasses: Record<TerminalLine['type'], string> = {
  cmd: 'text-fimil-400',
  out: 'text-transparent',
  ok: 'text-low',
  warn: 'text-medium',
  crit: 'text-critical',
};

const textClasses: Record<TerminalLine['type'], string> = {
  cmd: 'text-ink',
  out: 'text-ink-soft',
  ok: 'text-ink-soft',
  warn: 'text-ink-soft',
  crit: 'text-critical',
};
---

<div
  class:list={[
    'overflow-hidden rounded-xl border border-edge bg-code-bg shadow-2xl shadow-black/40',
    className,
  ]}
  data-terminal={animate ? 'animate' : 'static'}
>
  <div class="flex items-center gap-2 border-b border-edge bg-raised px-4 py-2.5">
    <div class="flex gap-1.5" aria-hidden="true">
      <span class="h-3 w-3 rounded-full bg-edge-bright"></span>
      <span class="h-3 w-3 rounded-full bg-edge-bright"></span>
      <span class="h-3 w-3 rounded-full bg-edge-bright"></span>
    </div>
    <span class="ml-2 font-mono text-xs text-ink-faint">{title}</span>
  </div>

  <div class="overflow-x-auto p-4 font-mono text-[13px] leading-6 whitespace-pre sm:p-5">
    {
      lines.map((line) => (
        <div data-line data-type={line.type}>
          <span class:list={['select-none', glyphClasses[line.type]]} aria-hidden="true">
            {glyphs[line.type] || ' '}
          </span>
          <span class:list={['ml-2', textClasses[line.type]]} data-text>
            {line.text}
          </span>
          <span class="terminal-caret hidden text-fimil-400" aria-hidden="true">
            &#9613;
          </span>
        </div>
      ))
    }
  </div>

  {
    animate && (
      <script
        is:inline
        type="application/json"
        data-terminal-script
        set:html={JSON.stringify(lines)}
      />
    )
  }
</div>

<script is:inline>
  (function () {
    if (window.__fimilTerminalInit) return;
    window.__fimilTerminalInit = true;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    document.querySelectorAll('[data-terminal="animate"]').forEach(function (term) {
      const dataEl = term.querySelector('script[data-terminal-script]');
      if (!dataEl) return;
      let lines;
      try {
        lines = JSON.parse(dataEl.textContent);
      } catch {
        return;
      }
      const lineEls = Array.from(term.querySelectorAll('[data-line]'));
      if (lineEls.length !== lines.length) return;

      lineEls.forEach(function (el) {
        el.style.visibility = 'hidden';
      });

      let started = false;

      function typeLine(el, text, done) {
        const textEl = el.querySelector('[data-text]');
        const caret = el.querySelector('.terminal-caret');
        textEl.textContent = '';
        el.style.visibility = 'visible';
        caret.classList.remove('hidden');
        let i = 0;
        const tick = setInterval(function () {
          i += 1;
          textEl.textContent = text.slice(0, i);
          if (i >= text.length) {
            clearInterval(tick);
            caret.classList.add('hidden');
            done();
          }
        }, 25);
      }

      function play(index) {
        if (index >= lines.length) return;
        const line = lines[index];
        const el = lineEls[index];
        const delay = typeof line.delay === 'number' ? line.delay : line.type === 'cmd' ? 400 : 250;
        setTimeout(function () {
          if (line.type === 'cmd') {
            typeLine(el, line.text, function () {
              play(index + 1);
            });
          } else {
            el.style.visibility = 'visible';
            play(index + 1);
          }
        }, delay);
      }

      const observer = new IntersectionObserver(
        function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting && !started) {
              started = true;
              observer.disconnect();
              play(0);
            }
          });
        },
        { threshold: 0.3 },
      );
      observer.observe(term);
    });
  })();
</script>
