---
// Shared window chrome for terminal demos, product mockups, and framed code.
interface Props {
  title?: string | undefined;
  variant?: 'terminal' | 'browser' | 'plain' | undefined;
  class?: string | undefined;
}

const { title, variant = 'terminal', class: className } = Astro.props;
---

<div
  class:list={[
    'overflow-hidden rounded-xl border border-edge bg-code-bg shadow-2xl shadow-black/40',
    className,
  ]}
>
  {
    variant !== 'plain' && (
      <div class="flex items-center gap-2 border-b border-edge bg-raised px-4 py-2.5">
        <div class="flex gap-1.5" aria-hidden="true">
          <span class="h-3 w-3 rounded-full bg-edge-bright" />
          <span class="h-3 w-3 rounded-full bg-edge-bright" />
          <span class="h-3 w-3 rounded-full bg-edge-bright" />
        </div>
        {variant === 'browser' ? (
          <span class="mx-auto rounded-md border border-edge bg-code-bg px-3 py-0.5 font-mono text-xs text-ink-faint">
            {title}
          </span>
        ) : (
          <span class="ml-2 font-mono text-xs text-ink-faint">{title}</span>
        )}
      </div>
    )
  }
  <slot />
</div>
