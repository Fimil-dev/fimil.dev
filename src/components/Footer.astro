---
const year = new Date().getFullYear();

const productLinks = [
  { label: 'AI Pentest', href: '/pentest' },
  { label: 'Platform', href: '/platform' },
  { label: 'Features', href: '/features' },
  { label: 'Pricing', href: '/pricing' },
  { label: 'Compare', href: '/compare' },
  { label: 'Changelog', href: '/changelog' },
];

const companyLinks = [
  { label: 'About', href: '/about' },
  { label: 'Blog', href: '/blog' },
  { label: 'Contact', href: '/contact' },
  { label: 'Security', href: '/security' },
];

const legalLinks = [
  { label: 'Privacy Policy', href: '/legal/privacy-policy' },
  { label: 'Terms of Service', href: '/legal/terms-of-service' },
  { label: 'Trust Center', href: 'https://trust.fimil.dev' },
  { label: 'DMCA', href: '/legal/dmca' },
  { label: 'Legal', href: '/legal' },
];
---

<footer class="border-t border-edge bg-ground">
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 gap-8 md:grid-cols-4">
      {/* Brand */}
      <div class="col-span-2 md:col-span-1">
        <a href="/" class="flex items-center">
          <img src="/logo-full-white.svg" alt="Fimil" class="h-8" />
        </a>
        <p class="mt-4 text-sm text-ink-faint">
          Application security that finds, proves, and fixes. Fifteen scanners plus an autonomous
          pentest agent, one signal.
        </p>
        <p class="mt-4 font-mono text-xs text-ink-faint">$ fimil scan</p>
      </div>

      {/* Product */}
      <div>
        <h3 class="text-sm font-semibold tracking-wider text-ink-faint uppercase">Product</h3>
        <ul class="mt-4 space-y-3">
          {
            productLinks.map((link) => (
              <li>
                <a href={link.href} class="text-sm text-ink-soft transition-colors hover:text-ink">
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      {/* Company */}
      <div>
        <h3 class="text-sm font-semibold tracking-wider text-ink-faint uppercase">Company</h3>
        <ul class="mt-4 space-y-3">
          {
            companyLinks.map((link) => (
              <li>
                <a href={link.href} class="text-sm text-ink-soft transition-colors hover:text-ink">
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      {/* Legal */}
      <div>
        <h3 class="text-sm font-semibold tracking-wider text-ink-faint uppercase">Legal</h3>
        <ul class="mt-4 space-y-3">
          {
            legalLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-ink-soft transition-colors hover:text-ink"
                  {...(link.href.startsWith('https://')
                    ? { target: '_blank', rel: 'noopener' }
                    : {})}
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <div class="mt-12 border-t border-edge pt-8 text-center text-sm text-ink-faint">
      &copy; {year} Fimil Inc. All rights reserved.
    </div>
  </div>
</footer>
