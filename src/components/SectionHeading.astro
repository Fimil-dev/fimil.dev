---
interface Props {
  eyebrow?: string | undefined;
  title: string;
  lead?: string | undefined;
  align?: 'center' | 'left' | undefined;
  id?: string | undefined;
}

const { eyebrow, title, lead, align = 'center', id } = Astro.props;
---

<div class:list={[align === 'center' ? 'mx-auto max-w-3xl text-center' : 'max-w-3xl', 'mb-12']}>
  {eyebrow && <p class="font-mono text-sm tracking-widest text-fimil-400 uppercase">{eyebrow}</p>}
  <h2 id={id} class="mt-3 text-3xl font-bold tracking-tight text-ink sm:text-4xl">{title}</h2>
  {lead && <p class="mt-4 text-lg text-ink-soft">{lead}</p>}
</div>
