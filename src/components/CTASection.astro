---
import Button from '@/components/Button.astro';

interface Props {
  headline: string;
  description?: string | undefined;
  cta: { label: string; href: string };
}

const { headline, description, cta } = Astro.props;
---

<section class="relative overflow-hidden border-y border-edge bg-panel py-16">
  <div
    class="pointer-events-none absolute inset-0"
    style="background: radial-gradient(60% 120% at 50% 0%, color-mix(in oklab, var(--color-fimil-500) 12%, transparent), transparent);"
    aria-hidden="true"
  >
  </div>
  <div class="relative mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
    <h2 class="text-2xl font-bold text-ink sm:text-3xl">{headline}</h2>
    {description && <p class="mx-auto mt-4 max-w-xl text-ink-soft">{description}</p>}
    <div class="mt-8">
      <Button href={cta.href} size="lg">{cta.label}</Button>
    </div>
  </div>
</section>
