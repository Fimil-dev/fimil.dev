---
interface Props {
  headline: string;
  description?: string | undefined;
  cta: { label: string; href: string };
}

const { headline, description, cta } = Astro.props;
---

<section class="bg-fimil-600 py-16">
  <div class="mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
    <h2 class="text-2xl font-bold text-white sm:text-3xl">{headline}</h2>
    {description && <p class="mx-auto mt-4 max-w-xl text-fimil-100">{description}</p>}
    <div class="mt-8">
      <a
        href={cta.href}
        class="inline-block min-w-[160px] rounded-lg border border-white px-6 py-3 text-base font-medium text-white transition-colors hover:bg-white hover:text-fimil-700"
      >
        {cta.label}
      </a>
    </div>
  </div>
</section>
