---
import Icon from '@/components/Icon.astro';
import type { IconName } from '@/lib/icons';

interface Props {
  title: string;
  description: string;
  icon?: IconName | undefined;
}

const { title, description, icon } = Astro.props;
---

<div
  class="rounded-2xl border border-edge bg-panel p-6 transition-colors hover:border-edge-bright hover:bg-raised"
>
  {
    icon && (
      <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl border border-fimil-400/20 bg-fimil-400/10">
        <Icon name={icon} class="h-5 w-5 text-fimil-400" />
      </div>
    )
  }
  <h3 class="mt-4 text-lg font-semibold text-ink">{title}</h3>
  <p class="mt-2 text-sm leading-6 text-ink-soft">{description}</p>
</div>
