---
interface Props {
  title: string;
  description: string;
  icon?: string | undefined;
}

const { title, description, icon } = Astro.props;
---

<div
  class="reveal group rounded-xl border border-gray-200 bg-white p-6 transition-shadow hover:shadow-lg dark:border-gray-800 dark:bg-gray-900"
>
  {
    icon && (
      <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-fimil-100 text-fimil-600 dark:bg-fimil-900/50 dark:text-fimil-400">
        <span class="text-xl">{icon}</span>
      </div>
    )
  }
  <h3 class="font-heading text-lg font-semibold text-gray-900 dark:text-white">{title}</h3>
  <p class="mt-2 text-sm leading-relaxed text-gray-600 dark:text-gray-400">{description}</p>
</div>
