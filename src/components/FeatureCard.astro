---
interface Props {
  title: string;
  description: string;
  icon?: string | undefined;
}

const { title, description, icon } = Astro.props;
---

<div
  class="group rounded-2xl border border-gray-200 bg-white p-6 transition-all hover:border-fimil-200 hover:shadow-lg"
>
  {
    icon && (
      <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-fimil-100 text-fimil-600 transition-colors group-hover:bg-fimil-600 group-hover:text-white">
        <span class="text-xl">{icon}</span>
      </div>
    )
  }
  <h3 class="mt-4 text-lg font-semibold text-gray-900">{title}</h3>
  <p class="mt-2 text-sm leading-6 text-gray-600">{description}</p>
</div>
