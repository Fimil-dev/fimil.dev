---
interface Props {
  headline: string;
  subheadline: string;
  primaryCta?: { label: string; href: string } | undefined;
  secondaryCta?: { label: string; href: string } | undefined;
}

const { headline, subheadline, primaryCta, secondaryCta } = Astro.props;

const hasVisual = Astro.slots.has('default');
---

<section
  class="relative overflow-hidden bg-gradient-to-b from-fimil-50 to-white py-24 sm:py-32 lg:py-40"
>
  {/* Decorative blobs */}
  <div
    class="absolute -top-40 -right-40 h-80 w-80 rounded-full bg-fimil-100 opacity-50 blur-3xl"
    aria-hidden="true"
  >
  </div>
  <div
    class="absolute -bottom-40 -left-40 h-80 w-80 rounded-full bg-fimil-100 opacity-50 blur-3xl"
    aria-hidden="true"
  >
  </div>

  <div
    class:list={[
      'relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8',
      hasVisual
        ? 'lg:grid lg:grid-cols-2 lg:items-center lg:gap-12'
        : 'mx-auto max-w-3xl text-center',
    ]}
  >
    {/* Text content */}
    <div class:list={[hasVisual ? 'text-center lg:text-left' : '']}>
      <h1 class="text-4xl font-bold tracking-tight text-gray-900 sm:text-5xl lg:text-6xl">
        {headline}
      </h1>
      <p
        class:list={[
          'mt-6 text-lg text-gray-600 sm:text-xl',
          hasVisual ? 'max-w-xl' : 'mx-auto max-w-2xl',
        ]}
      >
        {subheadline}
      </p>
      {
        (primaryCta || secondaryCta) && (
          <div
            class:list={[
              'mt-10 flex flex-col gap-4 sm:flex-row',
              hasVisual ? 'justify-center lg:justify-start' : 'items-center justify-center',
            ]}
          >
            {primaryCta && (
              <a
                href={primaryCta.href}
                class="min-w-[160px] rounded-lg bg-fimil-600 px-6 py-3 text-center text-base font-medium text-white shadow-sm transition-colors hover:bg-fimil-700"
              >
                {primaryCta.label}
              </a>
            )}
            {secondaryCta && (
              <a
                href={secondaryCta.href}
                class="min-w-[160px] rounded-lg border border-gray-300 bg-white px-6 py-3 text-center text-base font-medium text-gray-700 shadow-sm transition-colors hover:bg-gray-50"
              >
                {secondaryCta.label}
              </a>
            )}
          </div>
        )
      }
    </div>

    {/* Optional visual slot (e.g. DashboardMockup) */}
    {
      hasVisual && (
        <div class="flex flex-1 justify-center">
          <slot />
        </div>
      )
    }
  </div>
</section>
