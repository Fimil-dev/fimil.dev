---
interface Props {
  name: string;
  price: number | 'Custom';
  period?: string | undefined;
  description: string;
  features: string[];
  cta: { label: string; href: string };
  highlighted?: boolean | undefined;
}

const {
  name,
  price,
  period = 'month',
  description,
  features,
  cta,
  highlighted = false,
} = Astro.props;
---

<div
  class:list={[
    'relative flex flex-col rounded-2xl border p-8',
    highlighted
      ? 'border-fimil-600 bg-fimil-50 shadow-xl ring-1 ring-fimil-600'
      : 'border-gray-200 bg-white',
  ]}
>
  {
    highlighted && (
      <div class="absolute -top-4 left-1/2 -translate-x-1/2">
        <span class="inline-flex items-center rounded-full bg-fimil-600 px-4 py-1 text-xs font-semibold text-white">
          Most Popular
        </span>
      </div>
    )
  }

  <div class="mb-6">
    <h3 class="text-lg font-semibold text-gray-900">{name}</h3>
    <p class="mt-1 text-sm text-gray-500">{description}</p>
  </div>

  <div class="mb-6">
    {
      price === 'Custom' ? (
        <span class="text-4xl font-bold text-gray-900">Custom</span>
      ) : (
        <>
          <span class="text-4xl font-bold text-gray-900">${price}</span>
          {price > 0 && <span class="text-gray-500">/{period}</span>}
        </>
      )
    }
  </div>

  <ul class="mb-8 flex-1 space-y-3">
    {
      features.map((feature) => (
        <li class="flex items-start gap-3 text-sm text-gray-600">
          <svg
            class="mt-0.5 h-5 w-5 shrink-0 text-fimil-600"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
          {feature}
        </li>
      ))
    }
  </ul>

  <a
    href={cta.href}
    class:list={[
      'mt-8 block rounded-lg px-4 py-2.5 text-center text-sm font-medium transition-colors',
      highlighted
        ? 'bg-fimil-600 text-white hover:bg-fimil-700'
        : 'border border-gray-300 text-gray-700 hover:bg-gray-50',
    ]}
  >
    {cta.label}
  </a>
</div>
