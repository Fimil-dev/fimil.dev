---
import Icon from '@/components/Icon.astro';

interface Props {
  name: string;
  price: number | 'Custom';
  period?: string | undefined;
  description: string;
  features: string[];
  cta: { label: string; href: string };
  highlighted?: boolean | undefined;
}

const {
  name,
  price,
  period = 'month',
  description,
  features,
  cta,
  highlighted = false,
} = Astro.props;
---

<div
  class:list={[
    'relative flex flex-col rounded-2xl border p-8',
    highlighted ? 'border-fimil-400/40 bg-raised ring-1 ring-fimil-400/40' : 'border-edge bg-panel',
  ]}
>
  {
    highlighted && (
      <div class="absolute -top-4 left-1/2 -translate-x-1/2">
        <span class="inline-flex items-center rounded-full bg-fimil-400 px-4 py-1 text-xs font-semibold text-[#0a0e14]">
          Most Popular
        </span>
      </div>
    )
  }

  <div class="mb-6">
    <h3 class="text-lg font-semibold text-ink">{name}</h3>
    <p class="mt-1 text-sm text-ink-faint">{description}</p>
  </div>

  <div class="mb-6">
    {
      price === 'Custom' ? (
        <span class="font-mono text-4xl font-bold text-ink">Custom</span>
      ) : (
        <>
          <span class="font-mono text-4xl font-bold text-ink">${price}</span>
          {price > 0 && <span class="text-ink-faint">/{period}</span>}
        </>
      )
    }
  </div>

  <ul class="mb-8 flex-1 space-y-3">
    {
      features.map((feature) => (
        <li class="flex items-start gap-3 text-sm text-ink-soft">
          <Icon name="check" class="mt-0.5 h-5 w-5 shrink-0 text-fimil-400" />
          {feature}
        </li>
      ))
    }
  </ul>

  <a
    href={cta.href}
    class:list={[
      'mt-8 block rounded-lg px-4 py-2.5 text-center text-sm font-medium transition-colors',
      highlighted
        ? 'bg-fimil-400 text-[#0a0e14] hover:bg-fimil-300'
        : 'border border-edge-bright text-ink hover:bg-raised',
    ]}
  >
    {cta.label}
  </a>
</div>
