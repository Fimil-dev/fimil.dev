---
interface Props {
  title: string;
  description: string;
  iconRight?: boolean | undefined;
  bgGray?: boolean | undefined;
  iconEmoji?: string | undefined;
}

const { title, description, iconRight = true, bgGray = false, iconEmoji } = Astro.props;
---

<section class:list={['py-16 sm:py-20', bgGray ? 'bg-gray-50' : 'bg-white']}>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div
      class:list={[
        'scroll-hidden flex flex-col items-center gap-8 lg:flex-row lg:gap-16',
        !iconRight && 'lg:flex-row-reverse',
      ]}
    >
      {/* Text content */}
      <div class="flex-1">
        {
          iconEmoji && (
            <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-fimil-100 text-fimil-600">
              <span class="text-2xl">{iconEmoji}</span>
            </div>
          )
        }
        <h3 class="mt-6 text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">
          {title}
        </h3>
        <p class="mt-4 text-lg leading-8 text-gray-600">
          {description}
        </p>
      </div>

      {/* Icon / visual area */}
      <div class="flex flex-1 items-center justify-center">
        <div
          class="flex h-32 w-32 items-center justify-center rounded-2xl bg-gradient-to-br from-gray-100 to-gray-200 text-6xl shadow-lg sm:h-40 sm:w-40"
        >
          {iconEmoji || ''}
          <slot />
        </div>
      </div>
    </div>
  </div>
</section>
